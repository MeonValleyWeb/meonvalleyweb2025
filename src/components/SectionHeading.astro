---
export interface Props {
  level?: 1 | 2 | 3;
  title: string;
  eyebrow?: string;
  description?: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  level = 2,
  title,
  eyebrow,
  description,
  align = 'center',
  class: extraClass = '',
} = Astro.props;

const textAlign = align === 'center' ? 'text-center' : 'text-left';
const maxWidth = align === 'center' ? 'max-w-3xl mx-auto' : 'max-w-2xl';

const Tag = `h${level}`;
const titleSize =
  level === 1 ? 'text-5xl sm:text-6xl lg:text-7xl' : level === 2 ? 'text-3xl sm:text-4xl lg:text-5xl' : 'text-2xl';
---

<div class:list={[textAlign, maxWidth, extraClass, 'mb-12 lg:mb-16']}>
  {eyebrow && (
    <p class="text-sm font-semibold uppercase tracking-widest text-primary-600 mb-3">{eyebrow}</p>
  )}
  <Tag class:list={['font-bold text-gray-900 leading-tight tracking-tight', titleSize]}>
    {title}
  </Tag>
  {description && (
    <p class="mt-4 text-lg lg:text-xl text-gray-600 leading-relaxed">{description}</p>
  )}
</div>
