---
import Button from './Button.astro';
import Container from './Container.astro';

export interface Props {
  title: string;
  description?: string;
  href?: string;
  buttonText?: string;
  variant?: 'light' | 'primary' | 'dark';
}

const {
  title,
  description = '',
  href = '/contact',
  buttonText = 'Get in touch',
  variant = 'primary',
} = Astro.props;

const bgClass =
  variant === 'primary'
    ? 'bg-primary-600 text-white'
    : variant === 'dark'
      ? 'bg-gray-900 text-white'
      : 'bg-primary-50 text-gray-900';
const descClass = variant === 'light' ? 'text-gray-600' : 'opacity-90';
const buttonVariant: 'primary' | 'secondary' | 'outline' | 'ghost' =
  variant === 'dark' ? 'primary' : variant === 'primary' ? 'secondary' : 'primary';
---

<aside class={['py-16', bgClass]}>
  <Container class="text-center">
    <h2 class="text-3xl lg:text-4xl font-bold mb-4">{title}</h2>
    {description && <p class={['max-w-2xl mx-auto text-lg mb-8', descClass]}>{description}</p>}
    <Button href={href} variant={buttonVariant} size="lg">{buttonText}</Button>
  </Container>
</aside>
