---
// Header component
---

<header class="bg-white/90 backdrop-blur border-b border-gray-200/70 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20 md:h-24">
      <!-- Logo -->
      <div class="flex-shrink-0 py-3">
        <a href="/" class="flex items-center">
          <img src="/meon-valley-web-logo.svg" alt="Meon Valley Web" class="h-12 md:h-16 w-auto" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-6">
        <a href="/" class="text-gray-900 hover:text-primary-600 transition-colors duration-200 text-sm font-medium">
          Home
        </a>

        <!-- Services Mega Menu -->
        <div class="relative group">
          <button
            type="button"
            class="flex items-center gap-2 text-gray-900 hover:text-primary-600 transition-colors duration-200 text-sm font-medium"
            aria-haspopup="true"
          >
            Services
            <svg class="h-4 w-4 text-gray-400 group-hover:text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute left-1/2 top-full z-20 mt-4 w-[680px] -translate-x-1/2 opacity-0 pointer-events-none transition duration-200 group-hover:opacity-100 group-hover:pointer-events-auto group-focus-within:opacity-100 group-focus-within:pointer-events-auto">
            <span class="absolute -top-4 left-0 h-4 w-full"></span>
            <div class="rounded-2xl border border-gray-100 bg-white shadow-xl p-8">
              <div class="grid grid-cols-2 gap-6">
                <div class="space-y-3">
                  <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">Build</p>
                  <a href="/services" class="block rounded-xl border border-gray-100 p-4 hover:border-primary-200 hover:bg-primary-50/40 transition">
                    <p class="text-sm font-semibold text-gray-900">Web Development</p>
                    <p class="text-xs text-gray-500 mt-1">Bespoke sites, ecommerce, and web apps.</p>
                  </a>
                  <a href="/web-design-hampshire" class="block rounded-xl border border-gray-100 p-4 hover:border-primary-200 hover:bg-primary-50/40 transition">
                    <p class="text-sm font-semibold text-gray-900">Web Design</p>
                    <p class="text-xs text-gray-500 mt-1">Design-first builds for local businesses.</p>
                  </a>
                </div>
                <div class="space-y-3">
                  <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">Care & Hosting</p>
                  <a href="/wordpress-doctor" class="block rounded-xl border border-gray-100 p-4 hover:border-primary-200 hover:bg-primary-50/40 transition">
                    <p class="text-sm font-semibold text-gray-900">WordPress Doctor</p>
                    <p class="text-xs text-gray-500 mt-1">Fixes, tune-ups, and rescue projects.</p>
                  </a>
                  <a href="/wordpress-support-south-coast" class="block rounded-xl border border-gray-100 p-4 hover:border-primary-200 hover:bg-primary-50/40 transition">
                    <p class="text-sm font-semibold text-gray-900">WordPress Support</p>
                    <p class="text-xs text-gray-500 mt-1">Ongoing maintenance and updates.</p>
                  </a>
                  <a href="/wordpress-hosting-hampshire" class="block rounded-xl border border-gray-100 p-4 hover:border-primary-200 hover:bg-primary-50/40 transition">
                    <p class="text-sm font-semibold text-gray-900">WordPress Hosting</p>
                    <p class="text-xs text-gray-500 mt-1">Fast, secure managed hosting.</p>
                  </a>
                  <a href="/hosting" class="block rounded-xl border border-gray-100 p-4 hover:border-primary-200 hover:bg-primary-50/40 transition">
                    <p class="text-sm font-semibold text-gray-900">Hosting Plans</p>
                    <p class="text-xs text-gray-500 mt-1">Reliable infrastructure for growing sites.</p>
                  </a>
                </div>
              </div>
              <div class="mt-6 flex items-center justify-between rounded-xl bg-gray-50 px-5 py-4">
                <span class="text-sm text-gray-600">Need help deciding? We can guide you.</span>
                <a href="/contact" class="inline-flex items-center text-sm font-semibold text-primary-600 hover:text-primary-800">
                  Talk to us
                  <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <a href="/portfolio" class="text-gray-900 hover:text-primary-600 transition-colors duration-200 text-sm font-medium">
          Portfolio
        </a>

        <!-- Insights Dropdown -->
        <div class="relative group">
          <button
            type="button"
            class="flex items-center gap-2 text-gray-900 hover:text-primary-600 transition-colors duration-200 text-sm font-medium"
            aria-haspopup="true"
          >
            Insights
            <svg class="h-4 w-4 text-gray-400 group-hover:text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute left-1/2 top-full z-20 mt-4 w-72 -translate-x-1/2 opacity-0 pointer-events-none transition duration-200 group-hover:opacity-100 group-hover:pointer-events-auto group-focus-within:opacity-100 group-focus-within:pointer-events-auto">
            <span class="absolute -top-4 left-0 h-4 w-full"></span>
            <div class="rounded-2xl border border-gray-100 bg-white shadow-xl p-4 space-y-2">
              <a href="/newsroom" class="block rounded-xl border border-gray-100 p-4 hover:border-primary-200 hover:bg-primary-50/40 transition">
                <p class="text-sm font-semibold text-gray-900">Newsroom</p>
                <p class="text-xs text-gray-500 mt-1">Client wins, partnerships, and launches.</p>
              </a>
              <a href="/blog" class="block rounded-xl border border-gray-100 p-4 hover:border-primary-200 hover:bg-primary-50/40 transition">
                <p class="text-sm font-semibold text-gray-900">Blog</p>
                <p class="text-xs text-gray-500 mt-1">Advice on speed, UX, and growth.</p>
              </a>
            </div>
          </div>
        </div>

        <a href="/about" class="text-gray-900 hover:text-primary-600 transition-colors duration-200 text-sm font-medium">
          About
        </a>
        <a href="/charity" class="text-gray-900 hover:text-primary-600 transition-colors duration-200 text-sm font-medium">
          Charity
        </a>
        <a href="/contact" class="text-gray-900 hover:text-primary-600 transition-colors duration-200 text-sm font-medium">
          Contact
        </a>
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:flex">
        <a
          href="/contact"
          class="bg-gray-900 text-white px-5 py-2.5 rounded-full hover:bg-gray-800 transition-colors duration-200 text-sm font-semibold"
        >
          Get Started
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button
          type="button"
          class="text-gray-700 hover:text-primary-500 focus:outline-none focus:text-primary-500"
          id="mobile-menu-button"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden hidden" id="mobile-menu">
      <div class="px-2 pt-2 pb-4 space-y-1 sm:px-3 border-t border-gray-200">
        <a href="/" class="block px-3 py-2 text-gray-900 hover:text-primary-600 font-medium text-sm">Home</a>
        <a href="/services" class="block px-3 py-2 text-gray-900 hover:text-primary-600 font-medium text-sm">Services</a>
        <a href="/web-design-hampshire" class="block px-3 py-2 text-gray-700 hover:text-primary-600 text-sm">Web Design</a>
        <a href="/wordpress-doctor" class="block px-3 py-2 text-gray-700 hover:text-primary-600 text-sm">WordPress Doctor</a>
        <a href="/wordpress-support-south-coast" class="block px-3 py-2 text-gray-700 hover:text-primary-600 text-sm">WordPress Support</a>
        <a href="/wordpress-hosting-hampshire" class="block px-3 py-2 text-gray-700 hover:text-primary-600 text-sm">WordPress Hosting</a>
        <a href="/hosting" class="block px-3 py-2 text-gray-700 hover:text-primary-600 text-sm">Hosting Plans</a>
        <a href="/portfolio" class="block px-3 py-2 text-gray-900 hover:text-primary-600 font-medium text-sm">Portfolio</a>
        <a href="/newsroom" class="block px-3 py-2 text-gray-900 hover:text-primary-600 font-medium text-sm">Newsroom</a>
        <a href="/blog" class="block px-3 py-2 text-gray-900 hover:text-primary-600 font-medium text-sm">Blog</a>
        <a href="/about" class="block px-3 py-2 text-gray-900 hover:text-primary-600 font-medium text-sm">About</a>
        <a href="/charity" class="block px-3 py-2 text-gray-900 hover:text-primary-600 font-medium text-sm">Charity</a>
        <a href="/contact" class="block px-3 py-2 text-gray-900 hover:text-primary-600 font-medium text-sm">Contact</a>
        <a href="/contact" class="block mx-3 mt-4 bg-gray-900 text-white px-4 py-2 rounded-full hover:bg-gray-800 transition-colors duration-200 text-sm text-center font-semibold">
          Get Started
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuButton?.addEventListener('click', () => {
    const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
    mobileMenuButton.setAttribute('aria-expanded', (!isExpanded).toString());
    mobileMenu?.classList.toggle('hidden');
  });
</script>
