---
// Header component
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="text-2xl font-bold text-gray-900">
          Meon Valley <span class="text-primary-500">Web</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8">
        <a href="/" class="text-gray-600 hover:text-primary-500 transition-colors duration-200 font-medium">
          Home
        </a>
        <a href="/services" class="text-gray-600 hover:text-primary-500 transition-colors duration-200 font-medium">
          Services
        </a>
        <a href="/portfolio" class="text-gray-600 hover:text-primary-500 transition-colors duration-200 font-medium">
          Portfolio
        </a>
        <a href="/hosting" class="text-gray-600 hover:text-primary-500 transition-colors duration-200 font-medium">
          Hosting
        </a>
        <a href="/about" class="text-gray-600 hover:text-primary-500 transition-colors duration-200 font-medium">
          About
        </a>
        <a href="/contact" class="text-gray-600 hover:text-primary-500 transition-colors duration-200 font-medium">
          Contact
        </a>
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:flex">
        <a href="/contact" class="bg-primary-500 text-white px-6 py-2 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium">
          Get Started
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button type="button" class="text-gray-600 hover:text-primary-500 focus:outline-none focus:text-primary-500" id="mobile-menu-button">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden hidden" id="mobile-menu">
      <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3 border-t border-gray-100">
        <a href="/" class="block px-3 py-2 text-gray-600 hover:text-primary-500 font-medium">Home</a>
        <a href="/services" class="block px-3 py-2 text-gray-600 hover:text-primary-500 font-medium">Services</a>
        <a href="/portfolio" class="block px-3 py-2 text-gray-600 hover:text-primary-500 font-medium">Portfolio</a>
        <a href="/hosting" class="block px-3 py-2 text-gray-600 hover:text-primary-500 font-medium">Hosting</a>
        <a href="/about" class="block px-3 py-2 text-gray-600 hover:text-primary-500 font-medium">About</a>
        <a href="/contact" class="block px-3 py-2 text-gray-600 hover:text-primary-500 font-medium">Contact</a>
        <a href="/contact" class="block mx-3 mt-4 bg-primary-500 text-white px-6 py-2 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-center">
          Get Started
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>