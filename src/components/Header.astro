---
import { business, navigation } from '../data/site.ts';
import Icon from './Icon.astro';
import Button from './Button.astro';

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(`${href}/`);
}

function linkClasses(active: boolean) {
  return [
    'text-sm font-medium transition-colors duration-200 rounded-sm focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2',
    active ? 'text-primary-600' : 'text-gray-900 hover:text-primary-600',
  ].join(' ');
}
---

<header class="bg-white/90 backdrop-blur border-b border-gray-200/70 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20 md:h-24">
      <!-- Logo -->
      <div class="flex-shrink-0 py-3">
        <a href="/" class="flex items-center focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 rounded-sm" aria-label="Meon Valley Web home">
          <img src="/meon-valley-web-logo.svg" alt="Meon Valley Web" class="h-12 md:h-16 w-auto" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Main">
        {navigation.map((item) => {
          if (!item.children) {
            return (
              <a
                href={item.href}
                class={linkClasses(isActive(item.href))}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            );
          }

          const anyChildActive = item.children.some((child) => isActive(child.href));
          return (
            <div class="relative group" data-mega-menu
            >
              <button
                type="button"
                class={linkClasses(anyChildActive)}
                aria-expanded="false"
                aria-haspopup="true"
              >
                <span class="flex items-center gap-1">
                  {item.label}
                  <Icon name="chevronDown" class="w-4 h-4 text-gray-400 group-hover:text-primary-500 transition-transform" />
                </span>
              </button>
              <div
                class="absolute left-1/2 top-full z-20 mt-4 w-[680px] -translate-x-1/2 opacity-0 invisible transition duration-200 group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible bg-white rounded-2xl border border-gray-100 shadow-xl p-8"
                role="menu"
              >
                <span class="absolute -top-4 left-0 h-4 w-full"></span>
                <div class="grid grid-cols-2 gap-6">
                  {
                    item.children.map((child, idx, arr) => {
                      const mid = Math.ceil(arr.length / 2);
                      if (idx === 0 || idx === mid) {
                        const groupLabel = idx === 0 ? (item.label === 'Services' ? 'Build' : item.label) : 'Care & Hosting';
                        const groupItems = arr.slice(idx, idx === 0 ? mid : undefined);
                        return (
                          <div class="space-y-3" role="group" aria-label={groupLabel}>
                            <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">{groupLabel}</p>
                            {groupItems.map((c) => (
                              <a
                                href={c.href}
                                role="menuitem"
                                class="block rounded-xl border border-gray-100 p-4 hover:border-primary-200 hover:bg-primary-50/40 transition focus-visible:ring-2 focus-visible:ring-primary-500"
                                aria-current={isActive(c.href) ? 'page' : undefined}
                              >
                                <p class="text-sm font-semibold text-gray-900">{c.label}</p>
                                {'description' in c && c.description && (
                                  <p class="text-xs text-gray-500 mt-1">{c.description}</p>
                                )}
                              </a>
                            ))}
                          </div>
                        );
                      }
                      return null;
                    })
                  }
                </div>
                <div class="mt-6 flex items-center justify-between rounded-xl bg-gray-50 px-5 py-4">
                  <span class="text-sm text-gray-600">Need help deciding? We can guide you.</span>
                  <a
                    href="/contact"
                    class="inline-flex items-center text-sm font-semibold text-primary-600 hover:text-primary-800 focus-visible:ring-2 focus-visible:ring-primary-500"
                  >
                    Talk to us
                    <Icon name="chevronRight" class="w-4 h-4 ml-2" />
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </nav>

      <!-- Desktop CTA + Phone -->
      <div class="hidden md:flex items-center gap-4">
        <a
          href={business.phoneUrl}
          class="text-sm font-medium text-gray-700 hover:text-primary-600 flex items-center gap-2 focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 rounded-sm"
        >
          <Icon name="phone" class="w-4 h-4" />
          <span class="hidden lg:inline">{business.phone}</span>
        </a>
        <Button href="/contact" size="sm">Get Started</Button>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center gap-3 md:hidden">
        <a
          href={business.phoneUrl}
          class="p-2 text-gray-700 hover:text-primary-500 focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm"
          aria-label="Call us now"
        >
          <Icon name="phone" class="w-6 h-6" />
        </a>
        <button
          type="button"
          class="text-gray-700 hover:text-primary-500 focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm p-2"
          id="mobile-menu-button"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <Icon name="menu" class="w-6 h-6" />
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden hidden" id="mobile-menu" aria-label="Mobile">
      <div class="px-2 pt-2 pb-4 space-y-1 sm:px-3 border-t border-gray-200" role="menu">
        {navigation.map((item) => {
          if (!item.children) {
            return (
              <a
                href={item.href}
                role="menuitem"
                class="block px-3 py-2 rounded-md text-gray-900 hover:text-primary-600 font-medium text-sm"
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            );
          }
          return item.children.map((child) => (
            <a
              href={child.href}
              role="menuitem"
              class="block px-3 py-2 rounded-md text-gray-700 hover:text-primary-600 text-sm"
              aria-current={isActive(child.href) ? 'page' : undefined}
            >
              {child.label}
            </a>
          ));
        })}
        <div class="pt-4">
          <a
            href={business.phoneUrl}
            class="flex items-center gap-2 px-3 py-2 text-gray-700 text-sm font-medium"
          >
            <Icon name="phone" class="w-4 h-4" />
            {business.phone}
          </a>
          <Button href="/contact" variant="secondary" class="mt-2 w-full">Get Started</Button>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Live region for mobile menu state announcements -->
<div id="menu-status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

<script type="module">
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const status = document.getElementById('menu-status');
  if (button && menu && status) {
    button.addEventListener('click', () => {
      const expanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
      status.textContent = expanded ? 'Navigation menu closed.' : 'Navigation menu opened.';
    });
  }

  // Lightweight desktop keyboard handling for mega menus
  document.querySelectorAll('[data-mega-menu]').forEach((wrapper) => {
    const btn = wrapper.querySelector('button');
    const panel = wrapper.querySelector('[role="menu"');
    if (!btn || !panel) return;

    function open() {
      btn.setAttribute('aria-expanded', 'true');
      panel.classList.remove('opacity-0', 'invisible');
    }
    function close() {
      btn.setAttribute('aria-expanded', 'false');
      panel.classList.add('opacity-0', 'invisible');
    }

    btn.addEventListener('click', () => {
      btn.getAttribute('aria-expanded') === 'true' ? close() : open();
    });

    btn.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        open();
        const first = panel.querySelector('[role="menuitem"');
        first?.focus();
      }
      if (e.key === 'Escape') {
        close();
        btn.focus();
      }
    });

    wrapper.addEventListener('mouseleave', () => close());
  });
</script>
