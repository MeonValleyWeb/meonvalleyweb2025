---
import { business, footerNavigation, social } from '../data/site.ts';
import Icon from './Icon.astro';

const currentYear = new Date().getFullYear();

function linkClasses() {
  return 'text-gray-300 hover:text-primary-400 transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm';
}

const hasSocial = Object.values(social).some((url) => url.length > 0);
---

<footer class="bg-gray-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Company Info -->
      <div class="col-span-1 md:col-span-2">
        <div class="mb-4">
          <img src="/meon-valley-web-logo-white.svg" alt="Meon Valley Web" class="h-10 w-auto" />
        </div>
        <p class="text-gray-300 mb-4 max-w-md">
          Professional web development and hosting services for small to mid-size companies.
          We build modern, mobile-friendly websites that help your business grow.
        </p>

        <address class="not-italic text-gray-300 mb-4 text-sm">
          <span class="block">{business.address.locality}, {business.address.region}, {business.address.country}</span>
          <a href={`mailto:${business.email}`} class="block hover:text-primary-400">{business.email}</a>
          <a href={business.phoneUrl} class="block hover:text-primary-400">{business.phone}</a>
        </address>

        {hasSocial && (
          <div class="flex space-x-4">
            {social.twitter && (
              <a href={social.twitter} class="text-gray-400 hover:text-primary-400 transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm" aria-label="Follow us on Twitter (opens in new tab)" target="_blank" rel="noopener noreferrer">
                <Icon name="twitter" class="w-5 h-5" />
              </a>
            )}
            {social.facebook && (
              <a href={social.facebook} class="text-gray-400 hover:text-primary-400 transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm" aria-label="Follow us on Facebook (opens in new tab)" target="_blank" rel="noopener noreferrer">
                <Icon name="facebook" class="w-5 h-5" />
              </a>
            )}
            {social.linkedin && (
              <a href={social.linkedin} class="text-gray-400 hover:text-primary-400 transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm" aria-label="Connect with us on LinkedIn (opens in new tab)" target="_blank" rel="noopener noreferrer">
                <Icon name="linkedin" class="w-5 h-5" />
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Services -->
      <div>
        <h2 class="text-lg font-semibold mb-4">Services</h2>
        <ul class="space-y-2">
          {footerNavigation.services.map((link) => (
            <li>
              <a href={link.href} class={linkClasses()}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h2 class="text-lg font-semibold mb-4">Company</h2>
        <ul class="space-y-2">
          {footerNavigation.company.map((link) => (
            <li>
              <a href={link.href} class={linkClasses()}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-700 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-400 text-sm">
        © {currentYear} {business.name}. All rights reserved.
      </p>
      <div class="flex space-x-6">
        <a href="/privacy" class="text-gray-400 hover:text-primary-400 text-sm transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm">Privacy Policy</a>
        <a href="/terms" class="text-gray-400 hover:text-primary-400 text-sm transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm">Terms of Service</a>
      </div>
    </div>

    <!-- Charity Notice -->
    <div class="mt-6 p-4 bg-primary-900/20 rounded-lg border border-primary-800/30">
      <p class="text-primary-200 text-sm text-center">
        🤝 We build a website for a charity every quarter free of charge • 10% of profits go to charitable causes
      </p>
    </div>
  </div>
</footer>
