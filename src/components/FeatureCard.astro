---
import Icon from './Icon.astro';

export interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
  linkText?: string;
}

const { icon, title, description, href, linkText } = Astro.props;
---

<div class="flex flex-col items-center text-center p-6">
  <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mb-6">
    <Icon name={icon} class="w-8 h-8 text-primary-600" />
  </div>
  <h3 class="text-xl font-bold text-gray-900 mb-4">{title}</h3>
  <p class="text-gray-600 leading-relaxed">{description}</p>
  {href && linkText && (
    <p class="mt-4">
      <a href={href} class="font-semibold text-primary-600 hover:text-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500">
        {linkText}
        <span class="sr-only"> about {title}</span>
      </a>
    </p>
  )}
</div>
