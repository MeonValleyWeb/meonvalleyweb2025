---
export interface Props {
  quote: string;
  author: string;
  role?: string;
  rating?: number;
}

const { quote, author, role, rating = 5 } = Astro.props;

const stars = Array.from({ length: 5 }, (_, i) => i < rating);
---

<figure class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200 h-full flex flex-col">
  <blockquote class="text-lg text-gray-700 leading-relaxed flex-1">
    “{quote}”
  </blockquote>
  <figcaption class="mt-6 flex items-center gap-4">
    <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-lg">
      {author.charAt(0).toUpperCase()}
    </div>
    <div>
      <p class="font-semibold text-gray-900">{author}</p>
      {role && <p class="text-sm text-gray-500">{role}</p>}
      <div class="flex gap-0.5 mt-1" aria-label={`Rating: ${rating} out of 5`}>
        {stars.map((filled) => (
          <svg
            class={filled ? 'w-4 h-4 text-yellow-400' : 'w-4 h-4 text-gray-200'}
            fill="currentColor"
            viewBox="0 0 20 20"
            aria-hidden="true"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
    </div>
  </figcaption>
</figure>
