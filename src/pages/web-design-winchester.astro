---
import MainLayout from '../layouts/MainLayout.astro';
import SchemaFAQ from '../components/SchemaFAQ.astro';

const winchesterFAQs = [
  {
    question: "Do you work with Winchester businesses?",
    answer: "Yes, we work with businesses throughout Winchester and the surrounding areas. From the city centre around the Cathedral to businesses on the outskirts in SO22, SO23, and SO24 postcodes, we help local companies establish a professional online presence. Our Winchester clients include professional services, hospitality businesses, retailers, and educational institutions."
  },
  {
    question: "How much does a website cost in Winchester?",
    answer: "Our Winchester web design projects typically start from £2,500 for a professional small business website. This includes custom design, mobile optimisation, SEO setup, and CMS training. E-commerce websites for Winchester retailers start from £4,500. We provide transparent, fixed-price quotes with no hidden costs."
  },
  {
    question: "What areas around Winchester do you cover?",
    answer: "We serve businesses throughout Winchester including the city centre, Fulflood, Weeke, Stanmore, Badger Farm, and surrounding villages. We cover SO22, SO23, and SO24 postcodes. Whether you're based near the Cathedral, in a business park, or in the surrounding Hampshire countryside, we can help with your web design project."
  },
  {
    question: "Can you help Winchester hospitality businesses with websites?",
    answer: "Absolutely. Winchester's vibrant hospitality scene needs professional websites. We specialise in creating websites for Winchester restaurants, hotels, B&Bs, and pubs. Our designs include booking systems, menu displays, event calendars, and integration with reservation platforms. We understand what makes Winchester hospitality businesses unique."
  },
  {
    question: "Do you offer WordPress development for Winchester businesses?",
    answer: "Yes, WordPress is our primary platform for Winchester clients. We build custom WordPress themes, provide managed WordPress hosting with 99.9% uptime, security monitoring, and ongoing support packages. Whether you need a new WordPress site or improvements to an existing one, we have the expertise to help."
  },
  {
    question: "How long does it take to build a website for my Winchester business?",
    answer: "Most Winchester business websites are completed within 2-4 weeks from initial consultation to launch. Simple brochure sites can be ready in 2 weeks, while more complex projects with custom features take 4-6 weeks. We provide a detailed timeline and keep you updated throughout."
  },
  {
    question: "Can you help my Winchester business rank on Google?",
    answer: "Yes, all our websites are built with SEO best practices including fast loading, mobile optimisation, schema markup, and proper heading structures. For Winchester businesses specifically, we optimise for local search terms like 'web design Winchester' and service-specific keywords combined with location. We can also help optimise your Google Business Profile for local map visibility."
  }
];
---

<SchemaFAQ faqs={winchesterFAQs} />

<MainLayout 
  title="Web Design Winchester | Professional Website Development" 
  description="Expert web design services in Winchester. Custom WordPress & AstroJS websites for local businesses. Free consultation & Hampshire-based support."
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-32 bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Web Design <span class="text-primary-500">Winchester</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Professional website development for Winchester businesses. Serving the ancient capital 
          and surrounding Hampshire areas with modern, effective web solutions.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg">
            Get Free Quote
          </a>
          <a href="tel:+447850037850" class="border-2 border-primary-500 text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-medium text-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Benefits -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Web Design Services for Winchester
        </h2>
        <p class="text-xl text-gray-600">Local expertise for the ancient capital</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Heritage & Modern</h3>
          <p class="text-gray-600">
            We understand Winchester's unique blend of history and innovation. Your website will 
            reflect this balance, appealing to both traditional and modern audiences.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Transparent Pricing</h3>
          <p class="text-gray-600">
            No hidden costs or surprise fees. We provide clear, upfront pricing for Winchester 
            businesses with detailed project proposals.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Ongoing Support</h3>
          <p class="text-gray-600">
            Just 15 minutes from Winchester, we're available for in-person meetings, training sessions, 
            and ongoing website maintenance support.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Website Solutions for Winchester Businesses
        </h2>
        <p class="text-xl text-gray-600">From tourism to professional services</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Tourism & Hospitality</h3>
          <p class="text-gray-600 mb-4">
            Perfect for Winchester's hotels, B&Bs, restaurants, and tourist attractions. 
            Booking systems, galleries, and local area guides.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Online booking integration
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Photo galleries & virtual tours
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Local SEO for tourism
            </li>
          </ul>
        </div>
        
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Professional Services</h3>
          <p class="text-gray-600 mb-4">
            Websites for Winchester's solicitors, accountants, consultants, and professional firms. 
            Professional, trustworthy, and effective.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Professional design
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Client portal integration
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Secure document handling
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Frequently Asked Questions
        </h2>
        <p class="text-xl text-gray-600">Common questions about our Winchester web design services</p>
      </div>
      
      <div class="space-y-4">
        {winchesterFAQs.map((faq, index) => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <details class="group">
              <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                <h3 class="text-lg font-semibold text-gray-900 pr-4">{faq.question}</h3>
                <span class="transition-transform duration-200 group-open:rotate-180">
                  <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-gray-600 leading-relaxed">
                {faq.answer}
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        Ready to elevate your Winchester business?
      </h2>
      <p class="text-xl text-primary-100 mb-8">
        Free consultation for Winchester businesses. Let's discuss your website needs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors duration-200 font-medium text-lg">
          Start Your Project
        </a>
        <a href="/portfolio" class="border-2 border-white text-white px-8 py-4 rounded-lg hover:bg-white hover:text-primary-500 transition-colors duration-200 font-medium text-lg">
          View Our Work
        </a>
      </div>
    </div>
  </section>
</MainLayout>
