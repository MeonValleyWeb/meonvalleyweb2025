---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Web Design Hampshire | Meon Valley Web" description="Modern, conversion‑focused web design for Hampshire small businesses. WordPress and Astro builds with ongoing support.">
  <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
        Small business web design in <span class="text-primary-500">Hampshire</span>
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        We design fast, mobile‑friendly websites that generate leads and build trust.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-semibold text-lg">
          Start a project
        </a>
        <a href="/portfolio" class="border-2 border-primary-500 text-primary-600 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-semibold text-lg">
          View portfolio
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-gray-50 rounded-xl p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-2">Conversion‑focused</h2>
          <p class="text-gray-700">Clear messaging, strong calls‑to‑action, and trust signals.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-2">Modern builds</h2>
          <p class="text-gray-700">WordPress or Astro builds based on your business needs.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-2">Ongoing support</h2>
          <p class="text-gray-700">Maintenance and hosting available under one roof.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-primary-500">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl font-bold text-white mb-4">Ready to improve your site?</h2>
      <p class="text-xl text-primary-100 mb-6">We build sites that look great and perform even better.</p>
      <a href="/contact" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-semibold text-lg">
        Book a discovery call
      </a>
    </div>
  </section>
</MainLayout>
