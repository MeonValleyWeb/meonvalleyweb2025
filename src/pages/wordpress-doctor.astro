---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="WordPress Doctor Hampshire | Meon Valley Web" description="WordPress fixes, security, and maintenance for Hampshire and South Coast businesses.">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
        WordPress Doctor in <span class="text-primary-500">Hampshire</span> for fast fixes and ongoing care
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Diagnose, repair, and optimise your WordPress site with a senior specialist. 
        Perfect for businesses that need reliable fixes and peace of mind.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#booking-form" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-semibold text-lg">
          Request a WordPress fix
        </a>
        <a href="#what-we-fix" class="border-2 border-primary-500 text-primary-600 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-semibold text-lg">
          See what we fix
        </a>
      </div>
    </div>
  </section>

  <!-- What We Fix -->
  <section id="what-we-fix" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4">What we fix</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">From urgent repairs to performance clean‑ups.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Hacked sites</h3>
          <p class="text-gray-600">Malware removal, blacklist checks, and hardening to keep your site clean and secure.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Slow performance</h3>
          <p class="text-gray-600">Speed audits, caching, and Core Web Vitals improvements for faster load times.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Broken updates</h3>
          <p class="text-gray-600">Plugin/theme conflicts, safe rollbacks, and update fixes without breaking your site.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Errors & downtime</h3>
          <p class="text-gray-600">White screen of death, 500 errors, or crashes resolved quickly and safely.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Security issues</h3>
          <p class="text-gray-600">Vulnerability patching, login protection, firewall setup, and spam prevention.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Care plans</h3>
          <p class="text-gray-600">Optional monthly care: updates, monitoring, backups, and priority support.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4">How it works</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-xl font-bold text-gray-900 mb-3">1) Diagnose</h3>
          <p class="text-gray-600">We assess the issue and provide a clear action plan.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-xl font-bold text-gray-900 mb-3">2) Repair</h3>
          <p class="text-gray-600">We fix the root cause and verify stability.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-xl font-bold text-gray-900 mb-3">3) Protect</h3>
          <p class="text-gray-600">Optional ongoing care to keep things stable.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="booking-form" class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Request a WordPress Fix</h2>
        <p class="text-gray-600">Tell us what’s wrong and request a 30‑minute call. We’ll confirm by email.</p>
      </div>
      <form name="wordpress-doctor" method="POST" action="/thank-you" data-netlify="true" class="space-y-4">
        <input type="hidden" name="form-name" value="wordpress-doctor" />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <input name="name" type="text" placeholder="Your name" class="w-full border border-gray-300 rounded-lg px-4 py-3" required />
          <input name="email" type="email" placeholder="Your email" class="w-full border border-gray-300 rounded-lg px-4 py-3" required />
          <input
            name="phone"
            type="tel"
            inputmode="tel"
            autocomplete="tel"
            placeholder="Your mobile"
            pattern="^[\+]?[(]?[0-9]{1,4}[)]?[-\s\.]?[0-9]{1,4}[-\s\.]?[0-9]{1,9}$"
            title="Please enter a valid mobile number (e.g., +44 7123 456789 or 07123 456789)"
            class="w-full border border-gray-300 rounded-lg px-4 py-3"
            required
          />
        </div>
        <input name="website" type="url" placeholder="Website URL" class="w-full border border-gray-300 rounded-lg px-4 py-3" />
        <textarea name="issue" rows="4" placeholder="Describe the issue" class="w-full border border-gray-300 rounded-lg px-4 py-3" required></textarea>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-gray-600 mb-1" for="preferred_date">Preferred date</label>
            <input id="preferred_date" name="preferred_date" type="date" class="w-full border border-gray-300 rounded-lg px-4 py-3" required />
            <p class="text-xs text-gray-500 mt-1">Available Mon/Tue/Fri (next 2 weeks)</p>
          </div>
          <div>
            <label class="block text-sm text-gray-600 mb-1" for="preferred_time">Preferred time</label>
            <select id="preferred_time" name="preferred_time" class="w-full border border-gray-300 rounded-lg px-4 py-3" required>
              <option value="">Select a time</option>
            </select>
          </div>
        </div>
        <select name="urgency" class="w-full border border-gray-300 rounded-lg px-4 py-3">
          <option value="">Urgency</option>
          <option>Urgent (site down)</option>
          <option>Soon (errors / slow)</option>
          <option>Not urgent (general support)</option>
        </select>
        <div class="flex flex-col sm:flex-row gap-4">
          <button type="submit" class="bg-gray-900 text-white px-6 py-3 rounded-lg hover:bg-gray-800">Send request</button>
        </div>
      </form>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-primary-50 border border-primary-100 rounded-xl p-6 md:p-8 text-center">
        <h3 class="text-2xl font-bold text-gray-900 mb-3">Want a fully managed setup?</h3>
        <p class="text-gray-700 mb-4">
          If you prefer hands‑off hosting and maintenance, explore our managed WordPress hosting plans.
        </p>
        <a href="/hosting" class="inline-flex items-center text-primary-600 font-semibold hover:text-primary-700">
          See hosting plans →
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">WordPress Doctor FAQs</h2>
        <p class="text-xl text-gray-600">Quick answers before you book a check‑up.</p>
      </div>
      <div class="space-y-6">
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">How quickly can you start?</h3>
          <p class="text-gray-700">Most fixes can begin within 24–48 hours, depending on severity.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Do you fix hacked sites?</h3>
          <p class="text-gray-700">Yes. We clean, secure, and harden the site to prevent repeat incidents.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Is it one‑off or ongoing?</h3>
          <p class="text-gray-700">Both. You can book a one‑time repair or choose a maintenance plan.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Do you support WooCommerce?</h3>
          <p class="text-gray-700">Yes. We routinely fix and optimise WooCommerce sites.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">Need help right now?</h2>
      <p class="text-xl text-primary-100 mb-8 max-w-3xl mx-auto">
        Book a quick check‑up and we’ll advise the fastest path to resolution.
      </p>
      <a href="#booking-form" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-semibold text-lg">
        Request a WordPress fix
      </a>
    </div>
  </section>

  <script>
    (function () {
      const dateInput = document.getElementById('preferred_date');
      const timeSelect = document.getElementById('preferred_time');
      if (!dateInput || !timeSelect) return;

      const times = ['09:00','09:30','10:00','10:30','11:00','11:30'];
      const allowedDays = new Set([1, 2, 5]); // Mon, Tue, Fri

      const today = new Date();
      const max = new Date();
      max.setDate(today.getDate() + 13);

      const toISO = (d) => d.toISOString().split('T')[0];
      dateInput.min = toISO(today);
      dateInput.max = toISO(max);

      const clearTimes = () => {
        timeSelect.innerHTML = '<option value="">Select a time</option>';
      };

      const populateTimes = () => {
        clearTimes();
        const selectedDate = new Date(dateInput.value);
        if (isNaN(selectedDate.getTime())) return;

        if (!allowedDays.has(selectedDate.getDay())) {
          const opt = document.createElement('option');
          opt.value = '';
          opt.textContent = 'Not available on this day';
          timeSelect.appendChild(opt);
          return;
        }

        times.forEach((time) => {
          const opt = document.createElement('option');
          opt.value = time;
          opt.textContent = time;
          timeSelect.appendChild(opt);
        });
      };

      dateInput.addEventListener('change', populateTimes);
    })();
  </script>
</MainLayout>
