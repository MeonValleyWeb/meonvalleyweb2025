---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="WordPress Doctor | Meon Valley Web" description="Fix, secure, and optimise your WordPress site with fast diagnosis, repairs, and ongoing care options.">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
        WordPress Doctor for <span class="text-primary-500">fast fixes</span> and ongoing care
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Diagnose, repair, and optimise your WordPress site with a senior specialist. 
        Perfect for businesses that need reliable fixes and peace of mind.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-semibold text-lg">
          Request a WordPress check‑up
        </a>
        <a href="#what-we-fix" class="border-2 border-primary-500 text-primary-600 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-semibold text-lg">
          See what we fix
        </a>
      </div>
    </div>
  </section>

  <!-- What We Fix -->
  <section id="what-we-fix" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4">What we fix</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">From urgent repairs to performance clean‑ups.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Hacked sites</h3>
          <p class="text-gray-600">Malware removal, hardening, and recovery.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Slow performance</h3>
          <p class="text-gray-600">Speed audits, caching, and optimisation.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Broken updates</h3>
          <p class="text-gray-600">Plugin/theme conflicts, safe rollbacks.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Errors & downtime</h3>
          <p class="text-gray-600">White screen, 500 errors, or crashes.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Security issues</h3>
          <p class="text-gray-600">Vulnerabilities, failed logins, and spam.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Care plans</h3>
          <p class="text-gray-600">Optional ongoing maintenance and monitoring.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4">How it works</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-xl font-bold text-gray-900 mb-3">1) Diagnose</h3>
          <p class="text-gray-600">We assess the issue and provide a clear action plan.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-xl font-bold text-gray-900 mb-3">2) Repair</h3>
          <p class="text-gray-600">We fix the root cause and verify stability.</p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-xl font-bold text-gray-900 mb-3">3) Protect</h3>
          <p class="text-gray-600">Optional ongoing care to keep things stable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">Need help right now?</h2>
      <p class="text-xl text-primary-100 mb-8 max-w-3xl mx-auto">
        Book a quick check‑up and we’ll advise the fastest path to resolution.
      </p>
      <a href="/contact" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-semibold text-lg">
        Request a WordPress check‑up
      </a>
    </div>
  </section>
</MainLayout>
