---
import MainLayout from '../layouts/MainLayout.astro';
import SchemaFAQ from '../components/SchemaFAQ.astro';

const southamptonFAQs = [
  {
    question: "Do you work with Southampton businesses?",
    answer: "Yes, we work extensively with Southampton businesses across all sectors. From the city centre and Southampton Docks to the suburbs like Portswood, Bitterne, and Shirley, we help local companies establish a strong online presence. Our Southampton clients range from maritime businesses and retailers to professional services and startups."
  },
  {
    question: "How much does a website cost in Southampton?",
    answer: "Our Southampton web design projects typically start from £2,500 for a professional small business website. This includes custom design, mobile optimisation, basic SEO, and CMS training. E-commerce websites start from £4,500. We provide fixed-price quotes tailored to Southampton businesses with no hidden costs."
  },
  {
    question: "What areas in Southampton do you cover?",
    answer: "We serve businesses throughout Southampton including the City Centre, Ocean Village, Docks, Portswood, Bitterne, Shirley, Woolston, and surrounding areas. Whether you're based in SO14, SO15, SO16, SO17, SO18, SO19, or SO30-SO45 postcodes, we can help with your web design project."
  },
  {
    question: "Can you help Southampton businesses with e-commerce websites?",
    answer: "Absolutely. We specialise in e-commerce web design for Southampton retailers and businesses wanting to sell online. Using WooCommerce or custom solutions, we create online stores that integrate with local payment processors, support click-and-collect, and are optimised for converting Southampton customers."
  },
  {
    question: "Do you offer WordPress support for Southampton businesses?",
    answer: "Yes, we provide comprehensive WordPress services for Southampton businesses including custom theme development, plugin integration, hosting with 99.9% uptime, security monitoring, and ongoing maintenance packages. We can also help fix issues with existing WordPress sites."
  },
  {
    question: "How quickly can you build a website for my Southampton business?",
    answer: "Most Southampton business websites are completed within 2-4 weeks. Simple brochure sites can be ready in 2 weeks, while more complex projects with custom features take 4-6 weeks. We provide a detailed timeline during our free consultation and keep you updated throughout the build process."
  },
  {
    question: "Can you help my Southampton business rank on Google?",
    answer: "Yes, all our websites are built with SEO fundamentals including fast loading times, mobile optimisation, schema markup, and proper heading structures. For Southampton businesses specifically, we optimise for local search terms like 'web design Southampton' and your specific services combined with location keywords."
  }
];
---

<SchemaFAQ faqs={southamptonFAQs} />

<MainLayout 
  description="Expert web design services in Southampton. Custom WordPress, AstroJS & headless websites for local businesses. Free consultation & transparent pricing."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Web Design Hampshire', href: '/web-design-hampshire' },
    { name: 'Southampton' },
  ]}
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-32 bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Web Design <span class="text-primary-500">Southampton</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Professional website development for Southampton businesses. From the city centre to the docks, 
          we create modern, mobile-friendly websites that help Hampshire companies thrive online.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg">
            Get Free Quote
          </a>
          <a href="tel:+447850037850" class="border-2 border-primary-500 text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-medium text-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Benefits -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Why Southampton Businesses Choose Us
        </h2>
        <p class="text-xl text-gray-600">Hampshire-based web experts serving Southampton</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Fast Turnaround</h3>
          <p class="text-gray-600">
            Being just 20 minutes away means quick project delivery and the ability to meet in person 
            at your Southampton office whenever needed.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Industry Expertise</h3>
          <p class="text-gray-600">
            We understand Southampton's diverse economy - from maritime and logistics to retail and 
            professional services. Your website will speak to your market.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Local SEO</h3>
          <p class="text-gray-600">
            We optimise your site for Southampton-specific searches, helping you capture customers 
            searching for "web designer Southampton" and related terms.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services for Southampton -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Web Development Services in Southampton
        </h2>
        <p class="text-xl text-gray-600">Solutions tailored for Southampton businesses</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Business Websites</h3>
          <p class="text-gray-600 mb-4">
            Professional websites for Southampton companies. From corporate sites to small business 
            landing pages with contact forms and service showcases.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Responsive design
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              SEO optimised
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Fast hosting included
            </li>
          </ul>
        </div>
        
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">E-commerce Solutions</h3>
          <p class="text-gray-600 mb-4">
            Online stores for Southampton retailers. Sell products, manage inventory, 
            and accept payments securely with WooCommerce or Shopify integration.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Secure payments
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Inventory management
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Mobile shopping
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Southampton Areas Served -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Serving All of Southampton
        </h2>
        <p class="text-xl text-gray-600">We work with businesses across Southampton and surrounding areas</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">City Centre</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Ocean Village</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Chandlers Ford</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Eastleigh</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Bitterne</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Woolston</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Shirley</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Bassett</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Frequently Asked Questions
        </h2>
        <p class="text-xl text-gray-600">Common questions about our Southampton web design services</p>
      </div>
      
      <div class="space-y-4">
        {southamptonFAQs.map((faq, index) => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <details class="group">
              <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                <h3 class="text-lg font-semibold text-gray-900 pr-4">{faq.question}</h3>
                <span class="transition-transform duration-200 group-open:rotate-180">
                  <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-gray-600 leading-relaxed">
                {faq.answer}
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        Let's build your Southampton business online
      </h2>
      <p class="text-xl text-primary-100 mb-8">
        Free consultation for Southampton businesses. Get a transparent quote with no hidden costs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors duration-200 font-medium text-lg">
          Get Your Quote
        </a>
        <a href="/services" class="border-2 border-white text-white px-8 py-4 rounded-lg hover:bg-white hover:text-primary-500 transition-colors duration-200 font-medium text-lg">
          View Services
        </a>
      </div>
    </div>
  </section>
</MainLayout>
