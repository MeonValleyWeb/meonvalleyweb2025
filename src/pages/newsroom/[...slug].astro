---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('newsroom');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
}).format(entry.data.date);
---

<MainLayout title={`${entry.data.title} | Newsroom`} description={entry.data.description}>
  <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex flex-wrap justify-center gap-2 mb-6">
        {entry.data.category && (
          <span class="inline-flex items-center rounded-full bg-primary-100 text-primary-700 px-3 py-1 text-xs font-medium">
            {entry.data.category}
          </span>
        )}
        <span class="inline-flex items-center rounded-full bg-gray-100 text-gray-700 px-3 py-1 text-xs font-medium">
          {formattedDate}
        </span>
        {entry.data.author && (
          <span class="inline-flex items-center rounded-full bg-gray-100 text-gray-700 px-3 py-1 text-xs font-medium">
            {entry.data.author}
          </span>
        )}
      </div>
      <h1 class="text-4xl font-bold text-gray-900 sm:text-5xl mb-6">{entry.data.title}</h1>
      <p class="text-xl text-gray-600">{entry.data.description}</p>
    </div>
  </section>

  {entry.data.image && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="rounded-2xl overflow-hidden shadow-lg">
        <img
          src={entry.data.image}
          alt={entry.data.imageAlt || entry.data.title}
          class="w-full h-auto object-cover"
        />
      </div>
    </section>
  )}

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="content-area">
      <Content />
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <a
        href="/newsroom"
        class="inline-flex items-center text-primary-600 hover:text-primary-800 font-medium transition-colors duration-200"
      >
        <svg class="mr-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Newsroom
      </a>
      <a
        href="/contact"
        class="inline-flex items-center px-6 py-3 rounded-md text-white bg-primary-500 hover:bg-primary-600 transition-colors duration-200"
      >
        Start a project
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</MainLayout>

<style>
  .content-area :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .content-area :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .content-area :global(p) {
    color: #4b5563;
    margin-bottom: 1rem;
    line-height: 1.75;
  }

  .content-area :global(ul) {
    list-style-type: disc;
    list-style-position: inside;
    margin-bottom: 1rem;
    color: #4b5563;
  }

  .content-area :global(li) {
    margin-bottom: 0.5rem;
  }
</style>
