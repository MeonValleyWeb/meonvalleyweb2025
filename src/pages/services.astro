---
import MainLayout from '../layouts/MainLayout.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CtaBanner from '../components/CtaBanner.astro';

const pageTitle = 'Web Development Services | WordPress, Astro & Laravel | Meon Valley Web';
const description =
  'Professional web development services for Hampshire businesses: WordPress, headless WordPress with Astro, AstroJS, Laravel and fast managed hosting. Most projects from £2,500.';

const services = [
  {
    icon: 'wordpress',
    title: 'WordPress Development',
    summary:
      'Custom WordPress themes and functionality tailored to your business. From simple blogs to complex business websites with full content management capabilities.',
    pros: [
      'Easy content management for non-technical users',
      'Extensive plugin ecosystem for added functionality',
      'SEO-friendly with built-in optimisation tools',
      'Cost-effective for most business websites',
    ],
    cons: [
      'Requires regular updates and maintenance',
      'Performance depends on optimisation',
      'Security requires careful plugin/theme management',
    ],
  },
  {
    icon: 'bolt',
    title: 'Headless WordPress',
    summary:
      'The best of both worlds — WordPress for content management with a modern Astro frontend for outstanding performance and security.',
    pros: [
      'Ultra-fast loading speeds with static generation',
      'Familiar WordPress admin for content management',
      'Enhanced security by separating frontend and backend',
      'Excellent SEO and Core Web Vitals scores',
    ],
    cons: [
      'Higher initial development cost and complexity',
      'Content changes require rebuilds (usually automated)',
      'Limited real-time dynamic functionality without extra infrastructure',
    ],
  },
  {
    icon: 'rocket',
    title: 'Full AstroJS Development',
    summary:
      'Modern static site generation with dynamic capabilities. Perfect for marketing sites, portfolios, and content-heavy websites that prioritise speed.',
    pros: [
      'Exceptional performance with minimal JavaScript',
      'Built-in SEO and Core Web Vitals optimisation',
      'Component-based architecture for maintainability',
      'Markdown-based content management',
    ],
    cons: [
      'Content updates require technical knowledge',
      'Less dynamic functionality than WordPress out of the box',
      'Best suited for content that does not change frequently',
    ],
  },
  {
    icon: 'chart',
    title: 'Laravel Development',
    summary:
      'Robust web applications and APIs built with Laravel. Perfect for complex business logic, user management, and data-driven applications.',
    pros: [
      'Highly customisable for complex business requirements',
      'Robust user authentication and role management',
      'Excellent for API development and integrations',
      'Scalable architecture for growing applications',
    ],
    cons: [
      'Higher development cost and longer timeline',
      'Requires more server resources than static sites',
      'Ongoing maintenance and security updates needed',
    ],
  },
];

const localLinks = [
  {
    title: 'WordPress Hosting Hampshire',
    href: '/wordpress-hosting-hampshire',
    description: 'Managed hosting for local small businesses.',
  },
  {
    title: 'WordPress Support South Coast',
    href: '/wordpress-support-south-coast',
    description: 'Repairs, maintenance, and support across the coast.',
  },
  {
    title: 'Web Design Hampshire',
    href: '/web-design-hampshire',
    description: 'Conversion-focused design for Hampshire SMEs.',
  },
];
---

<MainLayout
  title={pageTitle}
  description={description}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Services' },
  ]}

>
  <!-- Hero -->
  <Section ariaLabel="Services hero" padding="xl" class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50">
    <Container class="text-center max-w-4xl">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight tracking-tight">
        Professional <span class="text-primary-500">web development</span>
      </h1>
      <p class="mt-6 text-xl text-gray-600 leading-relaxed">
        From simple business websites to complex e-commerce solutions, we deliver modern,
        mobile-friendly websites that help your business succeed online.
      </p>

      <div class="mt-10 bg-white rounded-xl p-6 shadow-lg border border-gray-200 max-w-3xl mx-auto text-left sm:text-center">
        <p class="text-lg text-gray-700 mb-2">
          <strong>Most small business projects start from £2,500.</strong>
        </p>
        <p class="text-gray-600">
          Small blogs and sites with fewer than 5 pages on an economy plan from £500, dependent on content.
        </p>
      </div>
    </Container>
  </Section>

  <!-- Services Grid -->
  <Section ariaLabel="What we build" class="bg-white">
    <Container>
      <SectionHeading
        title="Technology options"
        description="We match the right platform to your goals, budget, and in-house skills."
        align="center"
      />

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {services.map((service) => (
          <article class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
            <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-primary-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">{service.title}</h2>
            <p class="text-gray-600 mb-6 leading-relaxed">{service.summary}</p>

            <h3 class="sr-only">Advantages</h3>
            <ul class="space-y-2 mb-6">
              {service.pros.map((item) => (
                <li class="flex items-start text-gray-600">
                  <span class="text-green-500 mr-2 mt-1" aria-hidden="true">•</span>
                  {item}
                </li>
              ))}
            </ul>

            <h3 class="sr-only">Considerations</h3>
            <ul class="space-y-2">
              {service.cons.map((item) => (
                <li class="flex items-start text-gray-600">
                  <span class="text-orange-500 mr-2 mt-1" aria-hidden="true">•</span>
                  {item}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Hosting teaser -->
  <Section ariaLabel="Hosting and maintenance" class="bg-gray-50">
    <Container class="text-center max-w-3xl">
      <SectionHeading
        title="Hosting & maintenance"
        description="Reliable hosting is the foundation of a fast, secure website. Our managed plans start at £25/month and include daily backups, security updates, and UK business-hours support."
        align="center"
      />
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/hosting"
          class="inline-flex items-center justify-center px-8 py-4 rounded-lg bg-primary-500 text-white font-semibold text-lg hover:bg-primary-600 transition-colors focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
        >
          View hosting plans
        </a>
        <a
          href="/wordpress-support-south-coast"
          class="inline-flex items-center justify-center px-8 py-4 rounded-lg border-2 border-primary-500 text-primary-600 font-semibold text-lg hover:bg-primary-50 transition-colors focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
        >
          WordPress support
        </a>
      </div>
    </Container>
  </Section>

  <!-- Local services -->
  <Section ariaLabel="Local services in Hampshire and on the South Coast" class="bg-white">
    <Container>
      <SectionHeading
        title="Local services in Hampshire & on the South Coast"
        description="Focused landing pages for local search and specific services."
        align="center"
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {localLinks.map((link) => (
          <a
            href={link.href}
            class="block bg-gray-50 rounded-xl p-6 border border-gray-200 hover:border-primary-300 transition focus-visible:ring-2 focus-visible:ring-primary-500"
          >
            <h3 class="text-xl font-semibold text-gray-900 mb-2">{link.title}</h3>
            <p class="text-gray-700">{link.description}</p>
          </a>
        ))}
      </div>

      <div class="mt-10 flex justify-center flex-wrap gap-6">
        <a href="/hosting" class="text-primary-600 font-semibold hover:text-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm">
          Hosting plans →
        </a>
        <span class="text-gray-400" aria-hidden="true">|</span>
        <a href="/wordpress-doctor" class="text-primary-600 font-semibold hover:text-primary-700 focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm">
          WordPress Doctor →
        </a>
      </div>
    </Container>
  </Section>

  <CtaBanner
    title="Ready to get started?"
    description="Let’s discuss your project requirements and find the right development solution for your business. Free consultation and transparent pricing."
    buttonText="Get your free quote"
  />

</MainLayout>
