---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Web Development Services | Meon Valley Web" description="Professional web development services including WordPress, headless WordPress with Astro, AstroJS, Laravel, and fast hosting solutions.">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Professional <span class="text-primary-500">web development</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          From simple business websites to complex e-commerce solutions, we deliver 
          modern, mobile-friendly websites that help your business succeed online.
        </p>
        <div class="mt-8 bg-white rounded-xl p-6 shadow-lg border border-gray-200 max-w-4xl mx-auto">
          <p class="text-lg text-gray-700 mb-2">
            <strong>Most small business projects start from £2,500.</strong>
          </p>
          <p class="text-gray-600">
            Small blogs and sites with less than 5 pages on an economy plan from £500, dependent on content.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        
        <!-- WordPress Development -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M21.469 6.825c.84 1.537 1.318 3.3 1.318 5.175 0 3.979-2.156 7.456-5.363 9.325l3.295-9.527c.615-1.54.82-2.771.82-3.864 0-.405-.026-.78-.07-1.109m-7.981.105c.647-.03 1.232-.105 1.232-.105.582-.075.514-.93-.067-.899 0 0-1.755.135-2.88.135-1.064 0-2.85-.135-2.85-.135-.584-.031-.661.854-.082.899 0 0 .541.075 1.115.105l1.65 4.53-2.31 6.942-3.85-11.472c.647-.03 1.232-.105 1.232-.105.582-.075.516-.93-.065-.899 0 0-1.755.135-2.88.135-.202 0-.438-.008-.69-.015C4.911 2.015 8.235 0 12.001 0c2.8 0 5.349 1.07 7.268 2.826-.046-.003-.091-.009-.141-.009-1.06 0-1.812.923-1.812 1.914 0 .89.513 1.643 1.06 2.531.411.72.89 1.643.89 2.977 0 .915-.354 1.994-.821 3.479l-1.075 3.585-3.9-11.61.001.014zM12.001 24C5.382 24 0 18.618 0 12.001s5.382-12 12.001-12S24 5.384 24 12.001 18.618 24 12.001 24zM6.54 12.001c0-1.91.97-3.595 2.44-4.615L6.54 17.973c-1.45-1.65-2.34-3.78-2.34-6.172v.2z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">WordPress Development</h3>
          <p class="text-gray-600 mb-6">
            Custom WordPress themes and functionality tailored to your business needs. 
            From simple blogs to complex business websites with full content management capabilities.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-green-600 mb-3">✓ Advantages</h4>
            <ul class="space-y-2 mb-4">
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Easy content management for non-technical users
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Extensive plugin ecosystem for added functionality
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                SEO-friendly with built-in optimization tools
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Cost-effective for most business websites
              </li>
            </ul>
            
            <h4 class="text-lg font-semibold text-orange-600 mb-3">⚠ Considerations</h4>
            <ul class="space-y-2 mb-6">
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Requires regular updates and maintenance
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Can be slower than static sites without optimization
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Security considerations with plugins and themes
              </li>
            </ul>
          </div>
        </div>

        <!-- Headless WordPress + Astro -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Headless WordPress</h3>
          <p class="text-gray-600 mb-6">
            The best of both worlds - WordPress for content management with modern 
            frontend frameworks for lightning-fast performance and enhanced security.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-green-600 mb-3">✓ Advantages</h4>
            <ul class="space-y-2 mb-4">
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Ultra-fast loading speeds with static generation
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Familiar WordPress admin for content management
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Enhanced security with separated frontend/backend
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Superior SEO performance and Core Web Vitals
              </li>
            </ul>
            
            <h4 class="text-lg font-semibold text-orange-600 mb-3">⚠ Considerations</h4>
            <ul class="space-y-2 mb-6">
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Higher initial development cost and complexity
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Content changes require site rebuilds (usually automated)
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Limited real-time dynamic functionality
              </li>
            </ul>
          </div>
        </div>

        <!-- Full AstroJS -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16.074 16.86c-.72.616-2.157.769-3.567.769-1.41 0-2.847-.153-3.567-.769-.72-.616-.767-1.617-.104-2.28.663-.663 1.664-.616 2.28.104.616.72 1.617.767 2.28.104.663-.663.616-1.664-.104-2.28-.72-.616-1.617-.767-2.28-.104-.663.663-.616 1.664.104 2.28.72.616 2.157.769 3.567.769 1.41 0 2.847-.153 3.567-.769.72-.616.767-1.617.104-2.28-.663-.663-1.664-.616-2.28.104-.616.72-1.617.767-2.28.104-.663-.663-.616-1.664.104-2.28.72-.616 1.617-.767 2.28-.104.663.663.616 1.664-.104 2.28z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Full AstroJS Development</h3>
          <p class="text-gray-600 mb-6">
            Modern static site generation with dynamic capabilities. Perfect for 
            marketing sites, portfolios, and content-heavy websites that prioritize speed.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-green-600 mb-3">✓ Advantages</h4>
            <ul class="space-y-2 mb-4">
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Exceptional performance with minimal JavaScript
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Built-in SEO optimization and Core Web Vitals
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Component-based architecture for maintainability
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Markdown-based content management
              </li>
            </ul>
            
            <h4 class="text-lg font-semibold text-orange-600 mb-3">⚠ Considerations</h4>
            <ul class="space-y-2 mb-6">
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Content updates require technical knowledge
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Limited dynamic functionality compared to WordPress
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Best suited for content that doesn't change frequently
              </li>
            </ul>
          </div>
        </div>

        <!-- Laravel Development -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.642 5.43a.364.364 0 01.014.1v5.149c0 .135-.073.26-.189.326l-4.323 2.49v4.934a.378.378 0 01-.188.326L9.93 23.949a.316.316 0 01-.066.027c-.008.002-.016.008-.024.01a.348.348 0 01-.192 0c-.011-.002-.02-.008-.03-.012-.02-.008-.042-.014-.062-.025L.533 18.755a.376.376 0 01-.189-.326V2.974c0-.033.005-.066.014-.098.003-.012.01-.02.014-.032a.369.369 0 01.023-.058c.004-.013.015-.022.023-.033l.033-.045c.012-.01.025-.018.037-.027.014-.012.027-.024.041-.034H.53L5.043.05a.375.375 0 01.375 0L9.93 2.647h.002c.015.01.027.021.04.033.012.009.025.018.037.027.013.014.02.03.033.045.008.011.02.021.025.033.01.02.017.038.024.058.003.011.01.021.013.032.01.031.014.064.014.098v9.652l3.76-2.164V5.527c0-.033.004-.066.013-.098.003-.01.01-.02.013-.032a.487.487 0 01.024-.059c.007-.012.018-.02.025-.033.012-.015.021-.030.033-.043.012-.012.025-.02.037-.027.014-.013.026-.023.041-.032h.001l4.513-2.598a.375.375 0 01.375 0l4.513 2.598c.016.01.027.021.042.031.012.01.025.018.036.028.013.014.022.03.034.044.008.012.018.021.024.033.011.02.018.04.024.06.006.01.012.021.015.032zm-.74 5.032V6.179l-1.578.908-2.182 1.256v4.283zm-4.51 7.75v-4.287l-2.147 1.225-6.126 3.498v4.325zM1.093 3.624v14.588l8.273 4.761v-4.325l-4.322-2.445-.002-.003H5.04c-.014-.01-.025-.021-.04-.031-.011-.01-.024-.018-.035-.027l-.001-.002c-.013-.012-.021-.025-.031-.04-.01-.011-.021-.02-.028-.033-.002-.003-.006-.003-.009-.006-.008-.014-.013-.031-.02-.047-.006-.016-.014-.027-.018-.043a.49.49 0 01-.008-.057c-.002-.014-.006-.027-.006-.041V5.789l-2.18-1.257zM5.23.81L1.47 2.974l3.76 2.164 3.758-2.164zm1.956 13.505l2.182-1.256V3.624l-1.58.91-2.182 1.255v9.435zm11.581-10.95l-3.76 2.163 3.76 2.163 3.759-2.164zm-.376 4.978L16.21 7.087 14.63 6.18v4.283l2.182 1.256 1.58.908zm-8.65 9.654l5.514-3.148 2.756-1.572-3.757-2.163-4.323 2.489-3.941 2.27z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Laravel Development</h3>
          <p class="text-gray-600 mb-6">
            Robust web applications and APIs built with Laravel. Perfect for complex 
            business logic, user management, and data-driven applications that require custom functionality.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-green-600 mb-3">✓ Advantages</h4>
            <ul class="space-y-2 mb-4">
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Highly customizable for complex business requirements
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Robust user authentication and role management
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Excellent for API development and integrations
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-green-500 mr-2">•</span>
                Scalable architecture for growing applications
              </li>
            </ul>
            
            <h4 class="text-lg font-semibold text-orange-600 mb-3">⚠ Considerations</h4>
            <ul class="space-y-2 mb-6">
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Higher development cost and longer timeline
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Requires more server resources than static sites
              </li>
              <li class="flex items-start text-gray-600">
                <span class="text-orange-500 mr-2">•</span>
                Ongoing maintenance and security updates needed
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Development Services CTA -->
  <section class="py-20 bg-primary-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        Ready to get started?
      </h2>
      <p class="text-xl text-primary-100 mb-8 max-w-3xl mx-auto">
        Let's discuss your project requirements and find the perfect development solution for your business. 
        Free consultation and transparent pricing.
      </p>
      <a href="/contact" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-semibold text-lg">
        Get Your Free Quote
      </a>
    </div>
  </section>

  <!-- Hosting & Maintenance -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
          Hosting & Maintenance
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Choose the perfect hosting solution for your business needs.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Wayfarer Hosting Only -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="text-center mb-8">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Wayfarer</h3>
            <p class="text-sm text-gray-500 mb-4">Hosting Only</p>
            <div class="mb-4">
              <span class="text-5xl font-bold text-gray-900">£30</span>
              <span class="text-gray-600 ml-2">/ monthly</span>
            </div>
          </div>

          <ul class="space-y-4 mb-8">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Premium Storage</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Unlimited Bandwidth</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Free SSL Certificate</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Daily Automated Backups</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Email Support</span>
            </li>
          </ul>

          <a href="/contact" class="w-full bg-gray-900 text-white py-3 px-6 rounded-lg hover:bg-gray-800 transition-colors duration-200 font-medium text-center block">
            Get Hosting Only
          </a>
        </div>

        <!-- Shipwright Hosting & Maintenance -->
        <div class="bg-white rounded-2xl shadow-xl border-2 border-primary-500 p-8 relative">
          <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
            <span class="bg-primary-500 text-white px-4 py-2 rounded-full text-sm font-medium">Most Popular</span>
          </div>
          
          <div class="text-center mb-8">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Shipwright</h3>
            <p class="text-sm text-gray-500 mb-4">Hosting & Maintenance</p>
            <div class="mb-4">
              <span class="text-5xl font-bold text-gray-900">£75</span>
              <span class="text-gray-600 ml-2">/ monthly</span>
            </div>
          </div>

          <ul class="space-y-4 mb-8">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">All Wayfarer features +</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Plugin Checks & Updates</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Basic Security Monitoring</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">WordPress Core Updates</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Priority Email Support</span>
            </li>
          </ul>

          <a href="/contact" class="w-full bg-primary-500 text-white py-3 px-6 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-center block">
            Get Hosting & Maintenance
          </a>
        </div>

        <!-- Monarch Premium -->
        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200">
          <div class="text-center mb-8">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Monarch</h3>
            <p class="text-sm text-gray-500 mb-4">Premium Hosting & Maintenance</p>
            <div class="mb-4">
              <span class="text-5xl font-bold text-gray-900">£100</span>
              <span class="text-gray-600 ml-2">/ monthly</span>
            </div>
          </div>

