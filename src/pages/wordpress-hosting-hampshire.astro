---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="WordPress Hosting Hampshire | Meon Valley Web" description="Managed WordPress hosting in Hampshire with speed, security, backups, and real support for small businesses.">
  <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
        WordPress hosting in <span class="text-primary-500">Hampshire</span>
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Fast, secure, and fully managed hosting for Hampshire small businesses. Daily backups, monitoring, and real support.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <button type="button" onclick="openCalBooking()" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-semibold text-lg">
          Book a 30‑minute call
        </button>
        <a href="/hosting" class="border-2 border-primary-500 text-primary-600 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-semibold text-lg">
          View hosting plans
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Hosting built for Hampshire businesses</h2>
          <p class="text-gray-700 mb-4">
            You get managed WordPress hosting with a local partner who actually answers. We focus on speed, security, and clarity — no hidden fees, no confusing extras.
          </p>
          <p class="text-gray-700">
            Whether you run a trades business, local shop, or professional service, we keep your site fast and reliable so you can focus on customers.
          </p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Why clients choose us</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Local support with fast response times</li>
            <li>• Daily backups and proactive monitoring</li>
            <li>• Migration, DNS and optimisation handled end‑to‑end</li>
            <li>• Plans that scale as you grow</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-gray-50 rounded-xl p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-2">Speed & reliability</h2>
          <p class="text-gray-700">Optimised servers, caching, and 99.9% uptime so your site stays fast.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-2">Security & backups</h2>
          <p class="text-gray-700">Daily backups, monitoring, and proactive security for peace of mind.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-2">Local support</h2>
          <p class="text-gray-700">Real human support from Hampshire — no call centres.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">How the migration works</h2>
        <p class="text-gray-600">A simple, proven process with minimal downtime.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">1) Audit & plan</h3>
          <p class="text-gray-700">We review your current site and agree the migration window.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">2) Migrate & optimise</h3>
          <p class="text-gray-700">We migrate, tune performance, and harden security.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">3) Go live & monitor</h3>
          <p class="text-gray-700">DNS switch‑over and ongoing monitoring from day one.</p>
        </div>
      </div>
      <div class="text-center mt-8">
        <button type="button" onclick="openCalBooking()" class="inline-flex items-center text-primary-600 font-semibold hover:text-primary-700">
          Book a migration call →
        </button>
      </div>
    </div>
  </section>

  <section class="py-16 bg-primary-500">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl font-bold text-white mb-4">Ready to switch?</h2>
      <p class="text-xl text-primary-100 mb-6">We handle migration, DNS, and optimisation end‑to‑end.</p>
      <button type="button" onclick="openCalBooking()" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-semibold text-lg">
        Book a call
      </button>
    </div>
  </section>
</MainLayout>
