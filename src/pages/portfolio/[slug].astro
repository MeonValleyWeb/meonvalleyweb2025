---
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const portfolioEntries = await getCollection('portfolio');
  return portfolioEntries.map(entry => {
    // entry.id is like 'portfolio/filename'
    // Extract just the filename without the collection prefix and extension
    const slug = entry.id.split('/').pop()?.replace(/\.md$/, '') || '';
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const htmlContent = entry.body ? await marked(entry.body) : '';
---

<MainLayout 
  title={`${entry.data.title} - Portfolio`}
  description={entry.data.description}
   breadcrumbs={[
     { name: 'Home', href: '/' },
     { name: 'Portfolio', href: '/portfolio' },
     { name: entry.data.title },
   ]}
  >
  <!-- Hero Section -->
   <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-16">
     <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <!-- Project Meta -->
        <div class="flex flex-wrap justify-center gap-2 mb-6">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-700">
            {entry.data.technology}
          </span>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-700">
            {entry.data.category}
          </span>
          <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-medium ${
            entry.data.status === 'Live' ? 'bg-emerald-100 text-emerald-800' :
            entry.data.status === 'In Development' ? 'bg-yellow-100 text-yellow-800' :
            'bg-purple-100 text-purple-800'
          }`}>
            {entry.data.status}
          </span>
          {entry.data.timeline && (
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-700">
              {entry.data.timeline}
            </span>
          )}
          {entry.data.dataScale && (
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-700">
              {entry.data.dataScale}
            </span>
          )}
        </div>

        <h1 class="text-4xl font-bold text-gray-900 sm:text-5xl mb-6">
          {entry.data.title}
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          {entry.data.description}
        </p>
        
        <!-- Client Info -->
        <div class="text-lg text-gray-500">
          <span class="font-medium">Client:</span> {entry.data.client}
        </div>
      </div>
    </div>
    </section>
    <!-- Project Image -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {entry.data.image ? (
      <div class="rounded-lg shadow-lg overflow-hidden">
        <img 
          src={entry.data.image} 
          alt={entry.data.imageAlt || entry.data.title}
          class="w-full h-auto object-contain"
        />
      </div>
    ) : (
      <div class="aspect-video bg-gradient-to-br from-gray-100 to-gray-200 rounded-lg shadow-lg flex items-center justify-center">
        <div class="text-center text-gray-500">
          <svg class="w-24 h-24 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <p class="text-lg font-medium">Project Screenshot</p>
          <p class="text-sm text-gray-400">Image will be added soon</p>
        </div>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="content-area">
      <Fragment set:html={htmlContent} />
    </div>
  </div>

  <!-- Navigation -->
  <div class="bg-gray-50 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center">
        <a 
          href="/portfolio" 
          class="inline-flex items-center text-primary-600 hover:text-primary-800 font-medium transition-colors duration-200"
        >
          <svg class="mr-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Portfolio
        </a>
        
        <a 
          href="/contact" 
          class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-primary-500 hover:bg-primary-600 transition-colors duration-200"
        >
          Start Your Project
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .content-area :global(h1) {
    font-size: 1.875rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .content-area :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid #e5e7eb;
    padding-bottom: 0.75rem;
  }

  .content-area :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .content-area :global(p) {
    color: #4b5563;
    margin-bottom: 1.5rem;
    line-height: 1.75;
  }

  .content-area :global(ul) {
    list-style-type: disc;
    margin-bottom: 1.5rem;
    margin-left: 1.5rem;
  }

  .content-area :global(li) {
    color: #4b5563;
    margin-bottom: 0.5rem;
  }

  /* Code blocks */
  .content-area :global(pre) {
    background-color: #1f2937;
    color: #10b981;
    border-radius: 0.5rem;
    padding: 1.5rem;
    overflow-x: auto;
    font-family: 'Monaco', 'Courier New', monospace;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 1.5rem 0;
  }

  .content-area :global(code) {
    color: #10b981;
    background-color: #1f2937;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: 'Monaco', 'Courier New', monospace;
  }

  /* Inline code vs code blocks */
  .content-area :global(pre code) {
    background-color: transparent;
    color: inherit;
    padding: 0;
  }

  .content-area :global(blockquote) {
    border-left: 4px solid #7c3aed;
    background-color: #f9f5ff;
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    border-radius: 0 0.5rem 0.5rem 0;
    font-style: italic;
    color: #6b7280;
  }

  .content-area :global(a) {
    color: #7c3aed;
    text-decoration: none;
    font-weight: 500;
  }

  .content-area :global(a:hover) {
    color: #6d28d9;
    text-decoration: underline;
  }

  .content-area :global(strong) {
    font-weight: 600;
    color: #111827;
  }
</style>