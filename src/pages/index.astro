---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Professional Web Development & Hosting | Meon Valley Web">
  <!-- Hero Section -->
  <section class="py-20 lg:py-32 bg-white relative overflow-hidden">
    <!-- Background decorative elements -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-20 right-20 w-72 h-72 bg-primary-50 rounded-full opacity-60 blur-3xl"></div>
      <div class="absolute bottom-20 left-20 w-96 h-96 bg-green-50 rounded-full opacity-40 blur-3xl"></div>
    </div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-black mb-8 leading-[1.1] tracking-tight">
          Make better use of your<br />
          <span class="text-primary-500">web presence</span>
        </h1>
        <p class="text-xl lg:text-2xl text-gray-600 mb-12 leading-relaxed max-w-3xl mx-auto">
          Professional web development and hosting services for small to mid-size companies in the Meon Valley. 
          Modern, fast, and scalable websites that help your business grow.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
          <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg inline-flex items-center justify-center">
            Start Your Project Today
          </a>
        </div>
        
        <!-- Hero Image -->
        <div class="relative max-w-4xl mx-auto">
          <div class="bg-white rounded-2xl shadow-2xl border border-gray-200 p-8">
            <img src="/dashboard.jpg" alt="Meon Valley Web Dashboard - Professional Web Development" class="w-full h-auto rounded-xl" />
          </div>
          <!-- Floating stats -->
          <div class="absolute -top-4 -left-4 bg-white rounded-xl shadow-lg border border-gray-200 p-4">
            <div class="text-2xl font-bold text-black">50+</div>
            <div class="text-sm text-gray-600">Happy Customers</div>
          </div>
          <div class="absolute -top-4 -right-4 bg-white rounded-xl shadow-lg border border-gray-200 p-4">
            <div class="flex items-center mb-1">
              <div class="text-2xl font-bold text-black mr-2">5.0</div>
              <div class="flex">
                <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
                <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
                <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
                <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
                <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
              </div>
            </div>
            <div class="text-sm text-gray-600">Client Reviews</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trusted by Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-lg text-gray-600 mb-8">We trust our services and our clients to the most innovative companies in the world</p>
      </div>
      <!-- Technology Logos -->
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-8 items-center justify-items-center">
        <img src="/astro.png" alt="AstroJS" class="h-12 w-auto opacity-60 hover:opacity-100 transition-opacity" />
        <img src="/wordpress-tile.svg" alt="WordPress" class="h-12 w-auto opacity-60 hover:opacity-100 transition-opacity" />
        <img src="/laravel.png" alt="Laravel" class="h-12 w-auto opacity-60 hover:opacity-100 transition-opacity" />
        <img src="/ubuntu-2.svg" alt="Ubuntu" class="h-12 w-auto opacity-60 hover:opacity-100 transition-opacity" />
        <img src="/Netlify_logo.svg.png" alt="Netlify" class="h-12 w-auto opacity-60 hover:opacity-100 transition-opacity" />
        <img src="/spinupwp.png" alt="SpinupWP" class="h-12 w-auto opacity-60 hover:opacity-100 transition-opacity" />
        <img src="/Vercel_logo_black.svg" alt="Vercel" class="h-12 w-auto opacity-60 hover:opacity-100 transition-opacity" />
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-black mb-6">
          Appropriate features for proper web development
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Feature 1 -->
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Increases Brand Awareness</h3>
          <p class="text-gray-600 leading-relaxed">
            You want to stand out in your industry as a leader, but you also want to be seen as a relevant solution for your audience.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Amplifies SEO Success</h3>
          <p class="text-gray-600 leading-relaxed">
            Make sure you optimize your website for both desktop and mobile search results for maximum visibility and success.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Builds Customer Trust</h3>
          <p class="text-gray-600 leading-relaxed">
            Even with a strong SEO strategy, building customer trust in your brand takes time. Invest in quality content for readers.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Transparent Pricing</h3>
          <p class="text-gray-600 leading-relaxed">
            No hidden costs or surprise fees. Clear pricing from the start with ongoing support that fits your budget perfectly.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section with Image -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Left Content -->
        <div>
          <h2 class="text-4xl lg:text-5xl font-bold text-black mb-8 leading-tight">
            Take effective control of your web presence
          </h2>
          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            Meon Valley Web automatically handles all aspects of your website development and hosting. 
            Instant reports, seamless maintenance, and integrations with the tools your business loves.
          </p>
          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            We offer unlimited revisions and ongoing support with transparent pricing. This makes us perfect 
            for businesses with simple to complex web development needs. Available as both static sites 
            and dynamic applications for desktop and mobile.
          </p>
          <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg inline-flex items-center">
            Discover More
          </a>
        </div>
        
        <!-- Right Image -->
        <div class="relative">
          <div class="bg-white shadow-1xl p-4">
            <img src="/hal-gatewood-xzzgY__zX8A-unsplash.jpg" alt="Web Development Dashboard" class="w-full h-auto rounded-xl" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Tabs Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-black mb-6">
          We create world-class web design & development
        </h2>
      </div>
      
      <!-- Tab Navigation -->
      <div class="flex justify-center mb-12">
        <div class="bg-white rounded-xl p-2 shadow-lg border border-gray-200">
          <div class="flex space-x-2">
            <button class="tab-button active flex items-center px-6 py-3 rounded-lg font-medium text-sm transition-colors duration-200 bg-primary-500 text-white" data-tab="development">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
              Web Development
            </button>
            <button class="tab-button flex items-center px-6 py-3 rounded-lg font-medium text-sm transition-colors duration-200 text-gray-600 hover:text-gray-900" data-tab="hosting">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
              </svg>
              Hosting & Maintenance
            </button>
          </div>
        </div>
      </div>
      
      <!-- Tab Content -->
      <div class="tab-content" id="development">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-6">
            <h3 class="text-3xl font-bold text-black">Modern Web Development</h3>
            <p class="text-lg text-gray-600 leading-relaxed">
              We specialize in modern web development using the latest technologies. From WordPress 
              to headless solutions with Astro, and custom Laravel applications - we build websites 
              that are fast, secure, and scalable.
            </p>
            <ul class="space-y-3">
              <li class="flex items-center">
                <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-gray-700">Responsive design for all devices</span>
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-gray-700">SEO optimized from the ground up</span>
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-gray-700">Lightning-fast loading speeds</span>
              </li>
            </ul>
          </div>
          <div class="relative">
            <img src="/dashboard.jpg" alt="Web Development Portfolio" class="w-full h-auto rounded-xl shadow-lg" />
          </div>
        </div>
      </div>
      
      <div class="tab-content hidden" id="hosting">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-6">
            <h3 class="text-3xl font-bold text-black">Reliable Hosting & Maintenance</h3>
            <p class="text-lg text-gray-600 leading-relaxed">
              Our hosting solutions are built for performance and reliability. With daily backups, 
              security monitoring, and 99.9% uptime guarantee, your website will always be available 
              when your customers need it.
            </p>
            <ul class="space-y-3">
              <li class="flex items-center">
                <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-gray-700">Daily automated backups</span>
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-gray-700">24/7 security monitoring</span>
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
                <span class="text-gray-700">99.9% uptime guarantee</span>
              </li>
            </ul>
          </div>
          <div class="relative">
            <img src="/dashboard.jpg" alt="Hosting Dashboard" class="w-full h-auto rounded-xl shadow-lg" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEO Content Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Left Image -->
        <div class="relative">
          <div class="bg-white rounded-2xl p-8">
            <img src="/clark-tibbs-oqStl2L5oxI-unsplash.jpg" alt="SEO Performance Dashboard" class="w-full h-auto rounded-xl" />
          </div>
        </div>
        
        <!-- Right Content -->
        <div>
          <h2 class="text-4xl lg:text-5xl font-bold text-black mb-8 leading-tight">
            SEO gains momentum by increasing your investment
          </h2>
          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            SEO is often referred to as the 'long-term game' in the marketing world. The more time you invest, 
            the faster the benefits of SEO will accrue. As your website content grows, so does your visibility.
          </p>
          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            Search engine optimization ensures that your online presence is both articulated properly 
            and discoverable to potential customers.
          </p>
          
          <div class="space-y-6">
            <div class="flex items-start">
            
              <div>
                <h3 class="text-xl font-bold text-black mb-2">Keyword Research</h3>
                <p class="text-gray-600">Keyword research is the process of discovering valuable search queries that your customers use.</p>
              </div>
            </div>
            
            <div class="flex items-start">
              
              <div>
                <h3 class="text-xl font-bold text-black mb-2">Link Building</h3>
                <p class="text-gray-600">Link building is a SEO technique that increases your search engine ranking through quality backlinks.</p>
              </div>
            </div>
            
            <div class="flex items-start">
              
              <div>
                <h3 class="text-xl font-bold text-black mb-2">Ranking</h3>
                <p class="text-gray-600">It helps a website achieve top positions in the search engine results pages for relevant keywords.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-black mb-6">
          Perfect fit regardless of your specific budget
        </h2>
        <div class="flex justify-center mb-8">
          <div class="bg-white rounded-xl p-2 shadow-lg border border-gray-200">
            <div class="flex space-x-2">
              <button class="pricing-toggle active px-6 py-2 rounded-lg font-medium text-sm transition-colors duration-200" data-period="monthly">
                Per Month
              </button>
              <button class="pricing-toggle px-6 py-2 rounded-lg font-medium text-sm transition-colors duration-200" data-period="yearly">
                Per Year
                <span class="ml-2 bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full">Save 20%</span>
              </button>
            </div>
          </div>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Starter Plan -->
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8 relative">
          <div class="text-center mb-8">
            <h3 class="text-2xl font-bold text-black mb-4">Starter</h3>
            <div class="pricing-amount" data-monthly="£299" data-yearly="£2,390">
              <span class="text-5xl font-bold text-black">£299</span>
              <span class="text-gray-600 ml-2">/project</span>
            </div>
            <div class="pricing-period text-gray-600 mt-2" data-monthly="One-time payment" data-yearly="£2,390 yearly">
              One-time payment
            </div>
          </div>
          
          <ul class="space-y-4 mb-8">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">5-page WordPress website</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Mobile responsive design</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Basic SEO setup</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-green-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Contact form integration</span>
            </li>
          </ul>
          
          <a href="/contact" class="w-full bg-gray-900 text-white py-3 px-6 rounded-lg hover:bg-gray-800 transition-colors duration-200 font-medium text-center block">
            Get Started
          </a>
          <p class="text-center text-sm text-gray-500 mt-4">Perfect for small businesses</p>
        </div>

        <!-- Professional Plan -->
        <div class="bg-white rounded-2xl shadow-xl border-2 border-primary-500 p-8 relative">
          <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
            <span class="bg-primary-500 text-white px-4 py-2 rounded-full text-sm font-medium">Most Popular</span>
          </div>
          
          <div class="text-center mb-8">
