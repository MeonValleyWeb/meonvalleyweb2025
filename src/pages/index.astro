---
import MainLayout from '../layouts/MainLayout.astro';
import { locations } from '../data/site.ts';
import LeadMagnetPopup from '../components/LeadMagnetPopup.astro';
import TrustSignals from '../components/TrustSignals.astro';
import TechStrip from '../components/TechStrip.astro';
---

<MainLayout 
 title="Web Design Hampshire | Meon Valley Web"
 description="Web development and hosting for Hampshire small businesses. Request a free site audit, book a call, and start improving your website today."
>
 <!-- Hero: conversion-first -->
 <section class="relative overflow-hidden bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-16 lg:py-24" aria-label="Introduction">
 <div class="absolute inset-0 -z-10">
 <div class="absolute top-20 right-20 w-72 h-72 bg-primary-100 rounded-full opacity-40 blur-3xl"></div>
 <div class="absolute bottom-20 left-20 w-96 h-96 bg-primary-50 rounded-full opacity-30 blur-3xl"></div>
 </div>

 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
 <div class="max-w-2xl">
 <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-black mb-6 leading-[1.1] tracking-tight">
 Web development and hosting that grows your <span class="text-primary-500">Hampshire business</span>
 </h1>
 <p class="text-lg sm:text-xl text-gray-600 mb-8 leading-relaxed">
 Modern, fast websites and reliable WordPress hosting for small businesses across Hampshire and the South Coast. Clear pricing, local support, and no jargon.
 </p>

 <ul class="space-y-3 mb-10 text-gray-700">
 <li class="flex items-start gap-3">
 <svg class="w-6 h-6 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
 Free site audit video — see what’s costing you leads
 </li>
 <li class="flex items-start gap-3">
 <svg class="w-6 h-6 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
 Most websites from £2,500; hosting from £25/month
 </li>
 <li class="flex items-start gap-3">
 <svg class="w-6 h-6 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
 WordPress support, security updates and daily backups
 </li>
 </ul>

 <div class="flex flex-col sm:flex-row gap-4">
 <a href="/contact?subject=Free+site+audit" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg inline-flex items-center justify-center">
 Request a free site audit
 </a>
 <a href="/services" class="text-primary-500 hover:text-primary-600 px-8 py-4 rounded-lg font-medium text-lg inline-flex items-center justify-center underline">
 View services
 </a>
 </div>
 </div>

 <div class="relative">
 <div class="bg-white rounded-2xl shadow-2xl border border-gray-200 p-4 sm:p-6">
 <img
 src="/analytics-dashboard.webp"
 alt="Website analytics dashboard showing traffic growth"
 class="w-full h-auto rounded-xl object-cover"
 width="1090"
 height="790"
 fetchpriority="high"
 />
 </div>
 </div>
 </div>
 </div>
 </section>

 <!-- Site audit lead capture -->
 <section class="py-16 sm:py-20 bg-primary-500" aria-label="Free site audit offer">
 <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
 <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Not sure where your website stands?</h2>
 <p class="text-lg text-primary-100 mb-10 max-w-2xl mx-auto">
 Paste your website address below and we’ll send you a short video audit covering speed, mobile usability, SEO basics and quick wins.
 </p>

 <form name="site-audit" method="POST" data-netlify="true" action="/thank-you-checklist" class="max-w-3xl mx-auto">
 <input type="hidden" name="form-name" value="site-audit" />
 <div class="hidden" aria-hidden="true">
 <label>Do not fill this out if you are human: <input name="bot-field" type="text" aria-hidden="true" tabindex="-1" autocomplete="off" /></label>
 </div>

 <div class="flex flex-col sm:flex-row gap-4 mb-4">
 <div class="flex-[2] relative">
 <label for="audit-url" class="sr-only">Your website URL</label>
 <input
 id="audit-url"
 type="url"
 name="website"
 required
 placeholder="https://yourbusiness.co.uk"
 class="w-full px-4 py-4 rounded-lg border-2 border-white/30 bg-white text-gray-900 placeholder:text-gray-500 focus:outline-none focus:border-white focus:ring-2 focus:ring-white/40"
 />
 </div>
 <div class="flex-[2] relative">
 <label for="audit-email" class="sr-only">Your email address</label>
 <input
 id="audit-email"
 type="email"
 name="email"
 required
 placeholder="your@email.com"
 class="w-full px-4 py-4 rounded-lg border-2 border-white/30 bg-white text-gray-900 placeholder:text-gray-500 focus:outline-none focus:border-white focus:ring-2 focus:ring-white/40"
 />
 </div>
 <button type="submit" class="flex-[1] bg-gray-900 text-white px-6 py-4 rounded-lg hover:bg-gray-800 transition font-semibold shadow-lg">
 Get my audit
 </button>
 </div>
 <p class="text-sm text-primary-100">Free and confidential. No spam, unsubscribe anytime.</p>
 </form>
 </div>
 </section>

 <!-- Trust stats -->
 <TrustSignals />

 <!-- Unified "How we help" section -->
 <section class="py-20 bg-white" aria-label="What we do">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="text-center max-w-3xl mx-auto mb-16">
 <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-black mb-6">How we help you take control online</h2>
 <p class="text-lg text-gray-600">
 We combine modern development, reliable hosting and practical SEO so your site works harder for your business.
 </p>
 </div>

 <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-20">
 <div>
 <h3 class="text-2xl font-bold text-black mb-4">A website built to perform</h3>
 <p class="text-gray-600 mb-6 leading-relaxed">
 Whether you need WordPress, a headless CMS with Astro, or a Laravel application, we build sites that load fast, work on every device, and convert visitors into enquiries.
 </p>
 <ul class="space-y-3 mb-8 text-gray-700">
 <li class="flex items-center gap-3"><svg class="w-5 h-5 text-primary-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Responsive, accessible design</li>
 <li class="flex items-center gap-3"><svg class="w-5 h-5 text-primary-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> SEO baked in from day one</li>
 <li class="flex items-center gap-3"><svg class="w-5 h-5 text-primary-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Transparent, fixed-fee projects</li>
 </ul>
 <a href="/services" class="bg-primary-500 text-white px-6 py-3 rounded-lg hover:bg-primary-600 transition font-medium inline-flex items-center">
 Explore development
 </a>
 </div>
 <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-4">
 <img
 src="/search-console.webp"
 alt="Google Search Console showing improved search visibility"
 class="w-full h-auto rounded-xl"
 loading="lazy"
 decoding="async"
 width="1043"
 height="644"
 />
 </div>
 </div>

 <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
 <div class="order-2 lg:order-1 bg-white rounded-2xl shadow-xl border border-gray-100 p-4">
 <img
 src="/pagespeed-score.webp"
 alt="PageSpeed Insights score showing fast performance"
 class="w-full h-auto rounded-xl"
 loading="lazy"
 decoding="async"
 width="1085"
 height="673"
 />
 </div>
 <div class="order-1 lg:order-2">
 <h3 class="text-2xl font-bold text-black mb-4">Hosting and care that keeps you online</h3>
 <p class="text-gray-600 mb-6 leading-relaxed">
 Our managed WordPress hosting starts at £25/month and includes daily backups, Cloudflare DNS and SSL. Upgrade to a maintenance plan and we’ll handle updates, security and support.
 </p>
 <ul class="space-y-3 mb-8 text-gray-700">
 <li class="flex items-center gap-3"><svg class="w-5 h-5 text-primary-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Daily backups with 30-day retention</li>
 <li class="flex items-center gap-3"><svg class="w-5 h-5 text-primary-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> UK business-hours support</li>
 <li class="flex items-center gap-3"><svg class="w-5 h-5 text-primary-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Straightforward £50/month maintenance plan</li>
 </ul>
 <a href="/hosting" class="bg-primary-500 text-white px-6 py-3 rounded-lg hover:bg-primary-600 transition font-medium inline-flex items-center">
 See hosting plans
 </a>
 </div>
 </div>
 </div>
 </section>

 <!-- Service cards -->
 <section class="py-20 bg-gray-50" aria-label="Services overview">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="text-center max-w-3xl mx-auto mb-16">
 <h2 class="text-3xl sm:text-4xl font-bold text-black mb-4">Services built for your business</h2>
 <p class="text-lg text-gray-600">Everything from a brand-new site to ongoing care and emergency fixes.</p>
 </div>

 <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
 <a href="/services" class="group block bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-lg transition">
 <div class="w-14 h-14 bg-primary-100 rounded-xl flex items-center justify-center mb-6">
 <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
 </div>
 <h3 class="text-xl font-bold text-black mb-3 group-hover:text-primary-600 transition">Web Development</h3>
 <p class="text-gray-600 text-sm">Bespoke WordPress, Astro and Laravel builds designed around your goals. Most projects from £2,500.</p>
 </a>

 <a href="/hosting" class="group block bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-lg transition">
 <div class="w-14 h-14 bg-primary-100 rounded-xl flex items-center justify-center mb-6">
 <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path></svg>
 </div>
 <h3 class="text-xl font-bold text-black mb-3 group-hover:text-primary-600 transition">Hosting & Maintenance</h3>
 <p class="text-gray-600 text-sm">Managed hosting from £25/month with backups, support and optional maintenance plans.</p>
 </a>

 <a href="/wordpress-doctor" class="group block bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-lg transition">
 <div class="w-14 h-14 bg-primary-100 rounded-xl flex items-center justify-center mb-6">
 <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
 </div>
 <h3 class="text-xl font-bold text-black mb-3 group-hover:text-primary-600 transition">WordPress Doctor</h3>
 <p class="text-gray-600 text-sm">Urgent fixes for hacked, broken or slow WordPress sites. Diagnosis and repair for Hampshire businesses.</p>
 </a>
 </div>
 </div>
 </section>

 <!-- Testimonial -->
 <section class="py-20 bg-white" aria-label="Client testimonial">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center bg-gray-50 rounded-3xl p-8 lg:p-12">
 <div>
 <svg class="w-10 h-10 text-primary-300 mb-6" fill="currentColor" viewBox="0 0 24 24">
 <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-10zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h4v10h-10z"/>
 </svg>
 <blockquote class="text-xl sm:text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
 “The support and service provided by Andrew at Meon Valley Web is first class. He has created websites that effectively generate interest in my businesses, they are accessible and user friendly on all devices. The backup technical support is quick, reliable and always provides outstanding customer care.”
 </blockquote>
 <div>
 <p class="font-bold text-gray-900">Paul Fredericks</p>
 <p class="text-gray-600"><a href="https://twodogsandanawning.co.uk" target="_blank" rel="noopener noreferrer" class="hover:text-primary-600">Two Dogs and an Awning</a></p>
 </div>
 <div class="mt-8">
 <a href="/portfolio/walking-hiking-wordpress" class="text-primary-600 hover:text-primary-800 font-medium">View this project →</a>
 </div>
 </div>

 <div class="relative">
 <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-4">
 <img
 src="/portfolio/twodogsananawning.webp"
 alt="Two Dogs and an Awning website homepage"
 class="w-full h-auto rounded-xl object-cover"
 loading="lazy"
 decoding="async"
 />
 </div>
 </div>
 </div>
 </div>
 </section>

 <!-- Primary CTA -->
 <section class="py-20 bg-primary-500 text-white text-center" aria-label="Call to action">
 <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
 <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6">Ready to improve your website?</h2>
 <p class="text-xl text-primary-100 mb-10">
 Book a free consultation or request a short site audit. No pressure, just honest advice.
 </p>
 <div class="flex flex-col sm:flex-row gap-4 justify-center">
 <a href="/contact?subject=Free+site+audit" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-gray-100 transition font-medium text-lg inline-flex items-center justify-center">
 Request a free site audit
 </a>
 <a href="https://calendly.com/meonvalleyweb/30min" class="border-2 border-white text-white px-8 py-4 rounded-lg hover:bg-white hover:text-primary-500 transition font-medium text-lg inline-flex items-center justify-center" target="_blank" rel="noopener noreferrer">
 Book a call
 </a>
 </div>
 </div>
 </section>

 <!-- Areas we serve -->
 <section class="py-16 bg-gray-50" aria-label="Areas we serve">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="text-center mb-10">
 <h2 class="text-3xl font-bold text-black mb-3">Areas we serve</h2>
 <p class="text-lg text-gray-600 max-w-2xl mx-auto">
 Based in the Meon Valley, we work with businesses across Hampshire and the South Coast.
 </p>
 </div>
 <div class="flex flex-wrap justify-center gap-3">
 {locations.map((loc) => (
 <a
 href={`/web-design-${loc.slug}`}
 class="px-4 py-2 bg-white border border-gray-200 rounded-full text-gray-700 hover:bg-primary-50 hover:border-primary-300 hover:text-primary-600 transition-colors duration-200"
>
 {loc.name}
 </a>
 ))}
 </div>
 </div>
 </section>

 <!-- Tech strip -->
 <TechStrip />

 <!-- Popup -->
 <LeadMagnetPopup />
</MainLayout>
