---
import MainLayout from '../layouts/MainLayout.astro';
import { Image } from 'astro:assets';
import dashboardImg from '../assets/dashboard.jpg';
---

<MainLayout title="About Us | Meon Valley Web" description="Learn about Meon Valley Web - professional web development and hosting for small to mid-size companies. Modern methodologies, transparent pricing, and community commitment.">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-4">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          About <span class="text-primary-500">Meon Valley Web</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Professional web development studio specializing in modern, mobile-friendly websites 
          for small to mid-size companies. Based in the beautiful Meon Valley.
        </p>
      </div>
    </div>
  </section>

  <!-- Our Story Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Content -->
        <div>
          <h2 class="text-4xl lg:text-5xl font-bold text-black mb-8">
            Our Approach
          </h2>
          <div class="space-y-6 text-lg text-gray-600 leading-relaxed">
            <p>
              We believe in <strong class="text-black">development as code</strong> - using modern methodologies 
              and transparent processes to build websites that not only look great but perform exceptionally well.
            </p>
            <p>
              Every project follows our proven Development → Staging → Production workflow using 
              <a href="https://12factor.net/" class="text-black font-bold">
                12 Factor App
              </a> methodology. This ensures your website is built to professional standards 
              with proper version control and testing procedures.
            </p>
            <p>
              We combine technical expertise with a personal touch, delivering exceptional web 
              solutions that help your business grow online whilst being human.
            </p>
          </div>
        </div>
        
        <!-- Image placeholder -->
        <div class="relative">
          <div class="bg-white rounded-2xl shadow-2xl border border-gray-200 p-8">
            <Image 
              src={dashboardImg} 
              alt="Our Development Process" 
              class="w-full h-auto rounded-xl"
              widths={[400, 600, 800]}
              sizes="(max-width: 768px) 100vw, 50vw"
              format="webp"
              quality={80}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-black mb-6">
          What We Do
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          From simple business websites to complex applications, we deliver modern, 
          mobile-friendly solutions that help your business succeed online.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- WordPress Development -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M21.469 6.825c.84 1.537 1.318 3.3 1.318 5.175 0 3.979-2.156 7.456-5.363 9.325l3.295-9.527c.615-1.54.82-2.771.82-3.864 0-.405-.026-.78-.07-1.109m-7.981.105c.647-.03 1.232-.105 1.232-.105.582-.075.514-.93-.067-.899 0 0-1.755.135-2.88.135-1.064 0-2.85-.135-2.85-.135-.584-.031-.661.854-.082.899 0 0 .541.075 1.115.105l1.65 4.53-2.31 6.942-3.85-11.472c.647-.03 1.232-.105 1.232-.105.582-.075.516-.93-.065-.899 0 0-1.755.135-2.88.135-.202 0-.438-.008-.69-.015C4.911 2.015 8.235 0 12.001 0c2.8 0 5.349 1.07 7.268 2.826-.046-.003-.091-.009-.141-.009-1.06 0-1.812.923-1.812 1.914 0 .89.513 1.643 1.06 2.531.411.72.89 1.643.89 2.977 0 .915-.354 1.994-.821 3.479l-1.075 3.585-3.9-11.61.001.014zM12.001 24C5.382 24 0 18.618 0 12.001s5.382-12 12.001-12S24 5.384 24 12.001 18.618 24 12.001 24zM6.54 12.001c0-1.91.97-3.595 2.44-4.615L6.54 17.973c-1.45-1.65-2.34-3.78-2.34-6.172v.2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">WordPress Development</h3>
          <p class="text-gray-600">
            Custom themes and functionality tailored to your business needs. 
            From simple blogs to complex business websites.
          </p>
        </div>

        <!-- Headless WordPress + Astro -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Headless WordPress + Astro</h3>
          <p class="text-gray-600">
            The best of both worlds - WordPress for content management with 
            Astro's lightning-fast frontend performance.
          </p>
        </div>

        <!-- AstroJS Solutions -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16.074 16.86c-.72.616-2.157.769-3.567.769-1.41 0-2.847-.153-3.567-.769-.72-.616-.767-1.617-.104-2.28.663-.663 1.664-.616 2.28.104.616.72 1.617.767 2.28.104.663-.663.616-1.664-.104-2.28-.72-.616-1.617-.767-2.28-.104-.663.663-.616 1.664.104 2.28.72.616 2.157.769 3.567.769 1.41 0 2.847-.153 3.567-.769.72-.616.767-1.617.104-2.28-.663-.663-1.664-.616-2.28.104-.616.72-1.617.767-2.28.104-.663-.663-.616-1.664.104-2.28.72-.616 1.617-.767 2.28-.104.663.663.616 1.664-.104 2.28z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Full AstroJS Solutions</h3>
          <p class="text-gray-600">
            Lightning-fast static sites perfect for marketing sites, portfolios, 
            and content-heavy websites.
          </p>
        </div>

        <!-- Laravel Development -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.642 5.43a.364.364 0 01.014.1v5.149c0 .135-.073.26-.189.326l-4.323 2.49v4.934a.378.378 0 01-.188.326L9.93 23.949a.316.316 0 01-.066.027c-.008.002-.016.008-.024.01a.348.348 0 01-.192 0c-.011-.002-.02-.008-.03-.012-.02-.008-.042-.014-.062-.025L.533 18.755a.376.376 0 01-.189-.326V2.974c0-.033.005-.066.014-.098.003-.012.01-.02.014-.032a.369.369 0 01.023-.058c.004-.013.015-.022.023-.033l.033-.045c.012-.01.025-.018.037-.027.014-.012.027-.024.041-.034H.53L5.043.05a.375.375 0 01.375 0L9.93 2.647h.002c.015.01.027.021.04.033.012.009.025.018.037.027.013.014.02.03.033.045.008.011.02.021.025.033.01.02.017.038.024.058.003.011.01.021.013.032.01.031.014.064.014.098v9.652l3.76-2.164V5.527c0-.033.004-.066.013-.098.003-.01.01-.02.013-.032a.487.487 0 01.024-.059c.007-.012.018-.02.025-.033.012-.015.021-.030.033-.043.012-.012.025-.02.037-.027.014-.013.026-.023.041-.032h.001l4.513-2.598a.375.375 0 01.375 0l4.513 2.598c.016.01.027.021.042.031.012.01.025.018.036.028.013.014.022.03.034.044.008.012.018.021.024.033.011.02.018.04.024.06.006.01.012.021.015.032zm-.74 5.032V6.179l-1.578.908-2.182 1.256v4.283zm-4.51 7.75v-4.287l-2.147 1.225-6.126 3.498v4.325zM1.093 3.624v14.588l8.273 4.761v-4.325l-4.322-2.445-.002-.003H5.04c-.014-.01-.025-.021-.04-.031-.011-.01-.024-.018-.035-.027l-.001-.002c-.013-.012-.021-.025-.031-.04-.01-.011-.021-.02-.028-.033-.002-.003-.006-.003-.009-.006-.008-.014-.013-.031-.02-.047-.006-.016-.014-.027-.018-.043a.49.49 0 01-.008-.057c-.002-.014-.006-.027-.006-.041V5.789l-2.18-1.257zM5.23.81L1.47 2.974l3.76 2.164 3.758-2.164zm1.956 13.505l2.182-1.256V3.624l-1.58.91-2.182 1.255v9.435zm11.581-10.95l-3.76 2.163 3.76 2.163 3.759-2.164zm-.376 4.978L16.21 7.087 14.63 6.18v4.283l2.182 1.256 1.58.908zm-8.65 9.654l5.514-3.148 2.756-1.572-3.757-2.163-4.323 2.489-3.941 2.27z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Laravel Development</h3>
          <p class="text-gray-600">
            Robust web applications and APIs built with Laravel. Perfect for 
            complex business logic and data-driven applications.
          </p>
        </div>

        <!-- Fast Hosting -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Fast Hosting</h3>
          <p class="text-gray-600">
            Reliable, secure hosting solutions with 99.9% uptime guarantee, 
            daily backups, and security monitoring.
          </p>
        </div>

        <!-- Maintenance Plans -->
        <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Maintenance Plans</h3>
          <p class="text-gray-600">
            Ongoing support through our personal service. From basic support 
            to full management with weekly testing procedures.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Commitment Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-black mb-6">
          Our Commitment
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Every website we create is built to the highest standards with your success in mind.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Mobile-Friendly from the Start</h3>
          <p class="text-gray-600">
            Designed and tested across all devices to ensure your customers 
            can find you anywhere.
          </p>
        </div>

        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">SEO Optimized</h3>
          <p class="text-gray-600">
            Built to be found by your customers with proper SEO structure 
            and optimization from day one.
          </p>
        </div>

        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Fast Loading</h3>
          <p class="text-gray-600">
            Optimized for performance with modern development practices 
            and lightning-fast hosting.
          </p>
        </div>

        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Secure</h3>
          <p class="text-gray-600">
            Regular updates and security monitoring to keep your website 
            and visitors safe.
          </p>
        </div>

        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Backed Up Daily</h3>
          <p class="text-gray-600">
            Part of the Webmaster Backup Alliance with secure, 
            automated daily backups.
          </p>
        </div>

        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">No Hidden Costs</h3>
          <p class="text-gray-600">
            Transparent pricing with no surprises. What we quote 
            is what you pay.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Giving Back Section -->
  <section class="py-20 bg-primary-500 relative overflow-hidden">
    <!-- Background decorative elements -->
    <div class="absolute inset-0">
      <div class="absolute top-20 right-20 w-72 h-72 bg-white/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 left-20 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
          Giving Back to Our Community
        </h2>
        <p class="text-xl text-primary-100 max-w-3xl mx-auto">
          We're committed to making a positive impact in the Meon Valley and beyond.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-20 h-20 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">Charity Websites</h3>
          <p class="text-primary-100 text-lg">
            We build a website for a charity every quarter <strong class="text-white">free of charge</strong>
          </p>
        </div>

        <div class="text-center">
          <div class="w-20 h-20 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">Profit Sharing</h3>
          <p class="text-primary-100 text-lg">
            <strong class="text-white">10% of our profits</strong> go to charitable causes and community initiatives
          </p>
        </div>

        <div class="text-center">
          <div class="w-20 h-20 bg-white/20 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4">Local Support</h3>
          <p class="text-primary-100 text-lg">
            We support local businesses and community initiatives throughout Hampshire
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-black mb-6">
        Ready to work with us?
      </h2>
      <p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
        Let's discuss your project and find the perfect solution for your business. 
        Free consultation and transparent pricing.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg">
          Get Your Free Quote
        </a>
        <a href="/portfolio" class="border-2 border-gray-300 text-gray-700 px-8 py-4 rounded-lg hover:border-primary-500 hover:text-primary-500 transition-colors duration-200 font-medium text-lg">
          View Our Work
        </a>
      </div>
    </div>
  </section>
</MainLayout>