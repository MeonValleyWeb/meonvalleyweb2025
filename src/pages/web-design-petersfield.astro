---
import MainLayout from '../layouts/MainLayout.astro';
import SchemaFAQ from '../components/SchemaFAQ.astro';

const petersfieldFAQs = [
  {
    question: "Do you work with Petersfield businesses?",
    answer: "Yes, we work extensively with businesses in Petersfield and throughout East Hampshire. From the historic market town centre to businesses in surrounding villages like Liss, Liphook, and Sheet, we help local companies establish a strong online presence. Our Petersfield clients include professional services, independent retailers, tradespeople, and hospitality businesses."
  },
  {
    question: "How much does a website cost in Petersfield?",
    answer: "Our Petersfield web design projects typically start from £2,500 for a professional small business website. This includes custom design, mobile optimisation, basic SEO setup, and training on how to update your site. E-commerce websites start from £4,500. We provide transparent, fixed-price quotes with no hidden costs."
  },
  {
    question: "What areas around Petersfield do you cover?",
    answer: "We serve businesses throughout the Petersfield area including the town centre, GU31 and GU32 postcodes, and surrounding East Hampshire villages. Whether you're based near the Heath Pond, along the High Street, or in nearby villages like Steep or Stroud, we can help with your web design project."
  },
  {
    question: "Can you help Petersfield retailers sell online?",
    answer: "Absolutely. We specialise in e-commerce web design for Petersfield independent retailers and businesses wanting to reach customers online. Using WooCommerce or Shopify, we create online stores with secure payments, inventory management, and click-and-collect options. Perfect for Petersfield's unique independent shops."
  },
  {
    question: "Do you offer WordPress support for Petersfield businesses?",
    answer: "Yes, we provide comprehensive WordPress services for Petersfield businesses including custom theme development, managed hosting with 99.9% uptime, security monitoring, and ongoing maintenance packages. We can help with new WordPress sites or fix issues with existing ones."
  },
  {
    question: "How quickly can you build a website for my Petersfield business?",
    answer: "Most Petersfield business websites are completed within 2-4 weeks. Simple brochure sites can be ready in 2 weeks, while more complex projects with custom features take 4-6 weeks. We provide a detailed timeline during our free consultation and keep you updated throughout."
  },
  {
    question: "Can you help my Petersfield business rank on Google?",
    answer: "Yes, all our websites are built with SEO fundamentals including fast loading times, mobile optimisation, schema markup, and proper heading structures. For Petersfield businesses specifically, we optimise for local search terms like 'web design Petersfield' and your services combined with location keywords. We can also help optimise your Google Business Profile."
  }
];
---

<SchemaFAQ faqs={petersfieldFAQs} />

<MainLayout 
  title="Web Design Petersfield | Professional Website Development" 
  description="Expert web design services in Petersfield & East Hampshire. Custom websites for local businesses. Free consultation & Hampshire-based support."
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-32 bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Web Design <span class="text-primary-500">Petersfield</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Professional website development for Petersfield and East Hampshire businesses. 
          Modern, mobile-friendly websites that help local companies succeed online.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg">
            Get Free Quote
          </a>
          <a href="tel:+447850037850" class="border-2 border-primary-500 text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-medium text-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Benefits -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Local Web Design for Petersfield Businesses
        </h2>
        <p class="text-xl text-gray-600">East Hampshire's trusted web development partner</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Close to Home</h3>
          <p class="text-gray-600">
            Based in the Meon Valley, we're just 10 minutes from Petersfield. Available for 
            face-to-face meetings at your premises or ours.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Trusted Local Service</h3>
          <p class="text-gray-600">
            Supporting Petersfield businesses for years. We understand the local market 
            and build websites that attract East Hampshire customers.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Fast Results</h3>
          <p class="text-gray-600">
            Quick turnaround times for Petersfield businesses. Most websites ready in 2-4 weeks 
            with ongoing support always available.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Web Development Services for Petersfield
        </h2>
        <p class="text-xl text-gray-600">Complete solutions for East Hampshire businesses</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Small Business Websites</h3>
          <p class="text-gray-600 mb-4">
            Affordable, professional websites for Petersfield's independent shops, tradespeople, 
            and service providers. Perfect for getting online quickly.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Affordable packages
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Mobile responsive
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Local SEO included
            </li>
          </ul>
        </div>
        
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">WordPress & Maintenance</h3>
          <p class="text-gray-600 mb-4">
            Full WordPress development with ongoing care plans. We handle updates, security, 
            backups, and content changes so you can focus on your business.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Monthly maintenance
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Security updates
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Daily backups
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Areas Served -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Serving Petersfield & East Hampshire
        </h2>
        <p class="text-xl text-gray-600">We work with businesses across the region</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Petersfield</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Liss</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Horndean</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Clanfield</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Rowlands Castle</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">East Meon</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">West Meon</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Bishops Waltham</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Frequently Asked Questions
        </h2>
        <p class="text-xl text-gray-600">Common questions about our Petersfield web design services</p>
      </div>
      
      <div class="space-y-4">
        {petersfieldFAQs.map((faq, index) => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <details class="group">
              <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                <h3 class="text-lg font-semibold text-gray-900 pr-4">{faq.question}</h3>
                <span class="transition-transform duration-200 group-open:rotate-180">
                  <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-gray-600 leading-relaxed">
                {faq.answer}
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        Let's grow your Petersfield business online
      </h2>
      <p class="text-xl text-primary-100 mb-8">
        Free consultation for Petersfield and East Hampshire businesses. No obligation, just honest advice.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors duration-200 font-medium text-lg">
          Get Your Quote
        </a>
        <a href="/services" class="border-2 border-white text-white px-8 py-4 rounded-lg hover:bg-white hover:text-primary-500 transition-colors duration-200 font-medium text-lg">
          View Services
        </a>
      </div>
    </div>
  </section>
</MainLayout>
