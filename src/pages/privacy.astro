---
import MainLayout from '../layouts/MainLayout.astro';
import { readFileSync } from 'fs';
import { marked } from 'marked';
import { getCollection } from 'astro:content';

// Configure marked for better HTML output
marked.setOptions({
  breaks: true,
  gfm: true
});

// Load the legal entry to get frontmatter (must happen before awaiting at top level of module script)
const legalEntries = await getCollection('legal');
const privacyEntry = legalEntries.find((e) => e.id === 'privacy-policy' || e.id.includes('privacy-policy'));
const lastUpdated = privacyEntry?.data.lastUpdated || null;

// Read and parse the markdown file
const privacyContent = readFileSync('src/content/legal/_privacy-policy.md', 'utf-8');
const htmlContent = marked(privacyContent);
---

<MainLayout title="Privacy Policy | Meon Valley Web" description="Our privacy policy explains how we collect, use, and protect your personal data in compliance with UK GDPR and data protection laws.">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Privacy <span class="text-primary-500">Policy</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-8">
          We're committed to protecting your privacy and personal data. This policy explains how we collect, 
          use, and safeguard your information in compliance with UK GDPR and data protection laws.
        </p>
        <div class="bg-white rounded-xl p-4 shadow-lg border border-gray-200 inline-block">
          <p class="text-sm text-gray-500">
            <strong class="text-gray-900">Last updated:</strong> {lastUpdated ? new Date(lastUpdated).toLocaleDateString('en-GB', { year: 'numeric', month: 'long' }) : 'January 2025'}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="legal-content">
        <div set:html={htmlContent} />
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-200 max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Questions about your privacy?</h2>
        <p class="text-gray-600 mb-6">
          If you have any questions about how we handle your personal data or want to exercise your rights, 
          we're here to help.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="mailto:info@meonvalleyweb.com" class="bg-primary-500 text-white px-6 py-3 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium">
            Email Us
          </a>
          <a href="tel:+447850037850" class="border-2 border-primary-500 text-primary-500 px-6 py-3 rounded-lg hover:bg-primary-500 hover:text-white transition-colors duration-200 font-medium">
            Call Us
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style is:global>
  /* Clean, readable typography */
  .legal-content {
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
    color: #374151;
    line-height: 1.75;
    font-size: 1rem;
    max-width: none;
  }

  /* Hide markdown h1 since we have a hero */
  .legal-content h1 {
    display: none;
  }

  /* Add spacing after hidden h1 - targets first paragraph (Last updated) */
  .legal-content h1 + p {
    margin-top: 0;
    margin-bottom: 2.5rem;
    font-size: 0.9375rem;
    color: #6b7280;
  }

  /* Headings */
  .legal-content h2 {
    font-size: 1.875rem;
    font-weight: 800;
    color: #111827;
    margin-top: 4rem;
    margin-bottom: 1.5rem;
    border-bottom: 2px solid #e5e7eb;
    padding-bottom: 0.75rem;
    scroll-margin-top: 120px;
  }

  .legal-content h2:first-of-type {
    margin-top: 0;
  }

  .legal-content h3 {
    font-size: 1.375rem;
    font-weight: 700;
    color: #111827;
    margin-top: 3rem;
    margin-bottom: 1rem;
    scroll-margin-top: 120px;
  }

  /* Paragraphs */
  .legal-content p {
    margin: 1rem 0;
    color: #4b5563;
    line-height: 1.8;
  }

  /* Lists */
  .legal-content ul,
  .legal-content ol {
    margin: 0.75rem 0;
    padding-left: 1.5rem;
  }

  .legal-content li {
    margin: 0.5rem 0;
    color: #4b5563;
  }

  /* Horizontal rules */
  .legal-content hr {
    border: none;
    height: 1px;
    background: #e5e7eb;
    margin: 3rem 0;
  }

  /* Strong text - bold and darker */
  .legal-content strong {
    font-weight: 700;
    color: #111827;
  }

  /* Links */
  .legal-content a {
    color: #059669;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-content a:hover {
    color: #047857;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .legal-content h2 {
      font-size: 1.5rem;
    }
    .legal-content h3 {
      font-size: 1.125rem;
    }
  }
</style>