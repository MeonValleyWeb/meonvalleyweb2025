---
import MainLayout from '../layouts/MainLayout.astro';
import SchemaFAQ from '../components/SchemaFAQ.astro';

const eastleighFAQs = [
  {
    question: "Do you work with Eastleigh businesses?",
    answer: "Yes, we work extensively with businesses across Eastleigh. From the town centre and Swan Centre to industrial estates like Southampton Road and Woodside Avenue, we help local companies establish a professional online presence. Our Eastleigh clients include professional services, retailers, tradespeople, and industrial businesses."
  },
  {
    question: "How much does a website cost in Eastleigh?",
    answer: "Our Eastleigh web design projects typically start from £2,500 for a professional small business website. This includes custom design, mobile optimisation, basic SEO setup, and training. E-commerce and corporate websites start from £4,500. We provide transparent, fixed-price quotes with no hidden costs."
  },
  {
    question: "What areas in Eastleigh do you cover?",
    answer: "We serve businesses throughout Eastleigh including the town centre (SO50), surrounding areas in SO53, and nearby locations like Bishopstoke, Fair Oak, Horton Heath, and West End. Whether you're based in the town centre, a business park, or an industrial unit, we can help with your web design project."
  },
  {
    question: "Can you help Eastleigh industrial and B2B businesses?",
    answer: "Absolutely. Eastleigh has a strong industrial and B2B sector. We create professional websites for manufacturers, suppliers, and service companies. Our B2B designs include product catalogues, service showcases, client portals, and integration with business systems. We understand the unique needs of industrial businesses."
  },
  {
    question: "Do you offer WordPress development for Eastleigh businesses?",
    answer: "Yes, we provide comprehensive WordPress services for Eastleigh businesses including custom theme development, managed hosting with 99.9% uptime, security monitoring, and ongoing maintenance packages. We can help with new sites or improvements to existing WordPress websites."
  },
  {
    question: "How quickly can you build a website for my Eastleigh business?",
    answer: "Most Eastleigh business websites are completed within 2-4 weeks. Simple brochure sites can be ready in 2 weeks, while more complex projects take 4-6 weeks. We provide a detailed timeline during our free consultation and keep you updated throughout."
  },
  {
    question: "Can you help my Eastleigh business rank on Google?",
    answer: "Yes, all our websites are built with SEO fundamentals including fast loading times, mobile optimisation, schema markup, and proper heading structures. For Eastleigh businesses specifically, we optimise for local search terms like 'web design Eastleigh' and your services combined with location keywords."
  }
];
---

<SchemaFAQ faqs={eastleighFAQs} />

<MainLayout 
  description="Expert web design services in Eastleigh & Hampshire. Custom WordPress & AstroJS websites for local businesses. Free consultation."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Web Design Hampshire', href: '/web-design-hampshire' },
    { name: 'Eastleigh' },
  ]}
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-32 bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Web Design <span class="text-primary-500">Eastleigh</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Professional website development for Eastleigh businesses. Perfectly positioned between 
          Southampton and Portsmouth, we help Hampshire companies succeed online.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg">
            Get Free Quote
          </a>
          <a href="tel:+447850037850" class="border-2 border-primary-500 text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-medium text-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Benefits -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Why Eastleigh Businesses Choose Us
        </h2>
        <p class="text-xl text-gray-600">Central Hampshire's web development experts</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Perfectly Located</h3>
          <p class="text-gray-600">
            Just 15 minutes from Eastleigh, we're ideally placed to serve businesses across 
            central Hampshire between Southampton and Portsmouth.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Growth Partner</h3>
          <p class="text-gray-600">
            Eastleigh's growing business community needs websites that scale. We build flexible 
            platforms that grow with your company.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Competitive Pricing</h3>
          <p class="text-gray-600">
            Eastleigh businesses get agency-quality web design at rates that make sense. 
            Transparent pricing with no hidden costs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services for Eastleigh -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Web Development Services in Eastleigh
        </h2>
        <p class="text-xl text-gray-600">Serving central Hampshire businesses</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Business Websites</h3>
          <p class="text-gray-600 mb-4">
            Eastleigh's diverse business community needs professional web presence. From retail 
            at the Swan Centre to industrial estates, we cover all sectors.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Corporate branding
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Lead generation focus
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Multi-location support
            </li>
          </ul>
        </div>
        
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">WordPress Maintenance</h3>
          <p class="text-gray-600 mb-4">
            Keep your Eastleigh business website running smoothly with our care plans. 
            Updates, backups, security, and support all included.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Monthly updates
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Security monitoring
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Priority support
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Eastleigh Areas Served -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Serving Eastleigh & Surrounding Areas
        </h2>
        <p class="text-xl text-gray-600">Central Hampshire coverage</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Eastleigh Town Centre</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Bishopstoke</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Fair Oak</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Horton Heath</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">West End</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Chandler's Ford</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Boyatt Wood</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Velmore</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Eastleigh Section (Unique Content) -->
  <section class="py-20 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">
          Web Design at the Heart of Hampshire
        </h2>
        <p class="text-lg text-gray-600">
          Serving the SO50 postcode and central Hampshire's transport hub
        </p>
      </div>

      <div class="prose prose-lg max-w-none text-gray-700">
        <p class="mb-6">
          Eastleigh sits at the crossroads of Hampshire—literally. With its position on the main 
          railway line between Southampton and Portsmouth, and excellent road connections via the 
          M27 and M3, Eastleigh has grown from a railway town into a significant business centre. 
          The town's industrial estates and business parks are home to everything from aerospace 
          engineering to logistics companies, all needing professional web presence.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-10">
          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <h3 class="text-xl font-bold text-gray-900 mb-3">The Swan Centre & Retail</h3>
            <p class="text-gray-600">
              Eastleigh's modern shopping centre serves a catchment area that stretches well beyond 
              the town limits. We help retail and service businesses connect with this wider 
              audience through effective local SEO and compelling web design.
            </p>
          </div>

          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Eastleigh Industrial Heritage</h3>
            <p class="text-gray-600">
              From the historic railway works to modern business parks like Southampton 
              International Park, Eastleigh has always been about making and moving things. 
              We understand B2B businesses and create websites that generate qualified leads.
            </p>
          </div>
        </div>

        <p class="mb-6">
          Our Eastleigh clients reflect the town's diverse economy: engineering firms needing 
          technical credibility online, logistics companies showcasing their reach, retail 
          businesses connecting with customers, and professional services firms establishing 
          authority in their fields.
        </p>

        <p class="mb-6">
          The town's excellent connectivity—Eastleigh railway station is one of the busiest in 
          Hampshire—means businesses here often serve customers across the South Coast and 
          beyond. Your website should reflect that professional capability while maintaining 
          strong local search presence for "web design Eastleigh" and related terms.
        </p>

        <div class="bg-primary-50 p-6 rounded-xl border-l-4 border-primary-500 my-8">
          <p class="text-gray-800 italic">
            "As an engineering firm in Eastleigh, we needed a website that looked as professional 
            as our work. The new site has brought in quality enquiries from across Hampshire." 
            — David K., Eastleigh Business Park
          </p>
        </div>

        <h3 class="text-2xl font-bold text-gray-900 mb-4 mt-8">Areas We Cover Around Eastleigh</h3>
        <p class="mb-6">
          Eastleigh's influence extends across central Hampshire. We serve businesses throughout 
          the surrounding area:
        </p>

        <ul class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-8">
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Bishopstoke (SO50)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Fair Oak (SO50)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Horton Heath (SO50)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            West End (SO30)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Chandler's Ford (SO53)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Boyatt Wood (SO50)
          </li>
        </ul>

        <p class="mb-6">
          Whether you're looking for a simple brochure site to establish credibility, a lead 
          generation machine for your B2B services, or full e-commerce functionality, we 
          deliver solutions tailored to Eastleigh's competitive business environment.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Frequently Asked Questions
        </h2>
        <p class="text-xl text-gray-600">Common questions about our Eastleigh web design services</p>
      </div>
      
      <div class="space-y-4">
        {eastleighFAQs.map((faq, index) => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <details class="group">
              <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                <h3 class="text-lg font-semibold text-gray-900 pr-4">{faq.question}</h3>
                <span class="transition-transform duration-200 group-open:rotate-180">
                  <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-gray-600 leading-relaxed">
                {faq.answer}
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        Let's grow your Eastleigh business online
      </h2>
      <p class="text-xl text-primary-100 mb-8">
        Free consultation for central Hampshire businesses. Call <a href="tel:+447850037850" class="underline">07850 037850</a>.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors duration-200 font-medium text-lg">
          Get Your Quote
        </a>
        <a href="tel:+447850037850" class="border-2 border-white text-white px-8 py-4 rounded-lg hover:bg-white hover:text-primary-500 transition-colors duration-200 font-medium text-lg">
          Call 07850 037850
        </a>
      </div>
    </div>
  </section>
</MainLayout>
