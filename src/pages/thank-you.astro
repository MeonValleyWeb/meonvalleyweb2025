---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Thank You | Meon Valley Web" description="Thank you for contacting Meon Valley Web. We'll be in touch soon.">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-green-100 rounded-full mb-6">
          <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Thank You for <span class="text-primary-500">Getting in Touch!</span>
        </h1>
        
        <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-8">
          We've received your message and will review it carefully. You'll hear back from us within 24 hours during business days.
        </p>
      </div>
    </div>
  </section>

  <!-- What Happens Next -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">What Happens Next?</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-100 rounded-full mb-4">
            <span class="text-2xl font-bold text-primary-600">1</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">We Review Your Request</h3>
          <p class="text-gray-600">
            Our team will carefully review your project details and requirements to understand exactly what you need.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-100 rounded-full mb-4">
            <span class="text-2xl font-bold text-primary-600">2</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">We Get Back to You</h3>
          <p class="text-gray-600">
            Within 24 hours (business days), we'll reach out via email or phone to discuss your project in more detail.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-100 rounded-full mb-4">
            <span class="text-2xl font-bold text-primary-600">3</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">We Provide Your Quote</h3>
          <p class="text-gray-600">
            After our discussion, we'll send you a transparent, detailed quote with no hidden costs or surprises.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Information -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl p-8 shadow-lg max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Need to Reach Us Sooner?</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div class="text-center md:text-left">
            <div class="flex items-center justify-center md:justify-start mb-2">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              <span class="font-semibold text-gray-900">Email</span>
            </div>
            <a href="mailto:hello@meonvalleyweb.com" class="text-primary-600 hover:text-primary-700">
              hello@meonvalleyweb.com
            </a>
          </div>

          <div class="text-center md:text-left">
            <div class="flex items-center justify-center md:justify-start mb-2">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              <span class="font-semibold text-gray-900">Phone</span>
            </div>
            <a href="tel:+447850037850" class="text-primary-600 hover:text-primary-700">
              +44 (0) 7850 037850
            </a>
          </div>
        </div>

        <div class="text-center text-sm text-gray-600 border-t border-gray-200 pt-6">
          <p class="font-semibold text-gray-900 mb-2">Business Hours</p>
          <p>Monday - Friday: 9:00 AM - 6:00 PM GMT</p>
          <p>Saturday: 10:00 AM - 2:00 PM GMT</p>
          <p>Sunday: Closed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Read While You Wait -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-4 text-center">
        While You Wait: Helpful Resources
      </h2>
      <p class="text-lg text-gray-600 text-center mb-12 max-w-3xl mx-auto">
        Learn more about web design, pricing, and making the right decisions for your business.
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Article 1 -->
        <a href="/blog/how-much-does-website-cost-hampshire" class="bg-white p-6 rounded-xl shadow-md hover:shadow-lg transition-shadow duration-200 group">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-green-200 transition-colors">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-green-600 transition-colors">
            Website Costs in Hampshire
          </h3>
          <p class="text-gray-600 text-sm">
            Transparent pricing guide. Know what you'll pay before you start.
          </p>
        </a>

        <!-- Article 2 -->
        <a href="/blog/how-to-choose-web-designer" class="bg-white p-6 rounded-xl shadow-md hover:shadow-lg transition-shadow duration-200 group">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-blue-200 transition-colors">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">
            How to Choose a Web Designer
          </h3>
          <p class="text-gray-600 text-sm">
            10 essential questions to ask before hiring anyone.
          </p>
        </a>

        <!-- Article 3 -->
        <a href="/blog/ai-website-guide-business-owners" class="bg-white p-6 rounded-xl shadow-md hover:shadow-lg transition-shadow duration-200 group">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-purple-200 transition-colors">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-purple-600 transition-colors">
            AI on Your Website
          </h3>
          <p class="text-gray-600 text-sm">
            What business owners need to know about AI integration.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Quick Tips -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">
        Preparing for Your Project?
      </h2>
      
      <div class="bg-yellow-50 border-l-4 border-yellow-500 p-6 rounded-r-lg mb-8">
        <h3 class="font-bold text-gray-900 mb-2">💡 Tip: Gather Your Content Early</h3>
        <p class="text-gray-700">
          The #1 delay in web projects is waiting for content. Start collecting your text, images, 
          and any existing branding materials now. It'll speed up your project significantly.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-50 p-6 rounded-xl">
          <h4 class="font-semibold text-gray-900 mb-3">Things to Prepare:</h4>
          <ul class="space-y-2 text-gray-600 text-sm">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Logo files (vector format preferred)
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              High-quality photos of your work/team
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              List of services/products with descriptions
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Contact details and business hours
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Examples of websites you like
            </li>
          </ul>
        </div>

        <div class="bg-gray-50 p-6 rounded-xl">
          <h4 class="font-semibold text-gray-900 mb-3">Questions We'll Ask:</h4>
          <ul class="space-y-2 text-gray-600 text-sm">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"/>
              </svg>
              What are your main goals for this website?
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"/>
              </svg>
              Who is your target audience?
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"/>
              </svg>
              Do you need e-commerce functionality?
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"/>
              </svg>
              What's your timeline and budget range?
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"/>
              </svg>
              Do you have any existing branding?
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-primary-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">Explore More</h2>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/portfolio" class="bg-white text-primary-500 px-6 py-3 rounded-lg hover:bg-gray-100 transition-colors duration-200 font-medium">
          View Our Portfolio
        </a>
        <a href="/services" class="border-2 border-white text-white px-6 py-3 rounded-lg hover:bg-white hover:text-primary-500 transition-colors duration-200 font-medium">
          Our Services
        </a>
        <a href="/blog" class="border-2 border-white text-white px-6 py-3 rounded-lg hover:bg-white hover:text-primary-500 transition-colors duration-200 font-medium">
          Read Our Blog
        </a>
      </div>
    </div>
  </section>
</MainLayout>
