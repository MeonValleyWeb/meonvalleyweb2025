---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="WordPress Support South Coast | Meon Valley Web" description="Fast WordPress support and maintenance across the South Coast. Fixes, security, and performance improvements.">
  <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
        WordPress support on the <span class="text-primary-500">South Coast</span>
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        From emergency fixes to ongoing maintenance, we keep your WordPress site stable, secure, and fast.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/wordpress-doctor#booking-form" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-semibold text-lg">
          Request a WordPress fix
        </a>
        <a href="/wordpress-doctor" class="border-2 border-primary-500 text-primary-600 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-semibold text-lg">
          WordPress Doctor service
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Fast, reliable WordPress support</h2>
          <p class="text-gray-700 mb-4">
            We specialise in fixing broken sites, improving performance, and keeping WordPress secure. You’ll deal with a senior specialist, not a ticket queue.
          </p>
          <p class="text-gray-700">
            If your site generates leads or revenue, stability matters. We keep it running and recover it fast when things go wrong.
          </p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Our USP</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Rapid diagnosis and clear action plan</li>
            <li>• Transparent pricing with no hidden extras</li>
            <li>• Local support across the South Coast</li>
            <li>• Optional ongoing care plans</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-gray-50 rounded-xl p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-2">Emergency fixes</h2>
          <p class="text-gray-700">White screen, errors, or hacked? We diagnose and repair quickly.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-2">Security & updates</h2>
          <p class="text-gray-700">Patch vulnerabilities, update safely, and keep threats away.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h2 class="text-xl font-bold text-gray-900 mb-2">Performance tuning</h2>
          <p class="text-gray-700">Improve speed, Core Web Vitals, and stability.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Common issues we resolve</h2>
        <p class="text-gray-600">If any of these sound familiar, we can help.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Hacked or infected sites</h3>
          <p class="text-gray-700">Malware cleanup, blacklist removal, and hardening.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Slow load times</h3>
          <p class="text-gray-700">Core Web Vitals improvements and performance tuning.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Update failures</h3>
          <p class="text-gray-700">Fixes for plugin conflicts and broken updates.</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Downtime and errors</h3>
          <p class="text-gray-700">500 errors, white screens, and stability issues.</p>
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="/wordpress-doctor#booking-form" class="inline-flex items-center text-primary-600 font-semibold hover:text-primary-700">
          Request a fix →
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-primary-500">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl font-bold text-white mb-4">Need a reliable partner?</h2>
      <p class="text-xl text-primary-100 mb-6">We support South Coast businesses with friendly, expert WordPress care.</p>
      <a href="/wordpress-doctor#booking-form" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-semibold text-lg">
        Request a call
      </a>
    </div>
  </section>
</MainLayout>
