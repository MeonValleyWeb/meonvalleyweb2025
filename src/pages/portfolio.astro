---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const portfolioItems = await getCollection('portfolio');
const sortedPortfolio = portfolioItems.sort((a, b) => a.data.order - b.data.order);
---

<MainLayout 
  title="Portfolio - Meon Valley Web" 
  description="Explore our diverse portfolio of web development projects, from charity websites to complex data analysis platforms."
>
  <div class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-bold text-gray-900 sm:text-5xl lg:text-6xl">
          Our Portfolio
        </h1>
        <p class="mt-6 text-xl text-gray-600 max-w-3xl mx-auto">
          Discover the diverse range of projects we've delivered, from charity websites and ecommerce platforms to innovative data analysis tools and rapid-deployment solutions.
        </p>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid gap-12 lg:gap-16">
      {sortedPortfolio.map((project, index) => (
        <article class="group">
          <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
            <!-- Project Image -->
            <div class={`order-2 ${index % 2 === 0 ? 'lg:order-1' : 'lg:order-2'}`}>
              {project.data.image ? (
                <div class="rounded-lg shadow-lg group-hover:shadow-xl transition-shadow duration-300 overflow-hidden">
                  <img 
                    src={project.data.image} 
                    alt={project.data.imageAlt || project.data.title}
                    class="w-full h-auto object-contain group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
              ) : (
                <div class="aspect-video bg-gradient-to-br from-gray-100 to-gray-200 rounded-lg shadow-lg group-hover:shadow-xl transition-shadow duration-300 flex items-center justify-center">
                  <div class="text-center text-gray-500">
                    <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    <p class="text-sm font-medium">Project Image</p>
                    <p class="text-xs text-gray-400">Coming Soon</p>
                  </div>
                </div>
              )}
            </div>

            <!-- Project Content -->
            <div class={`order-1 ${index % 2 === 0 ? 'lg:order-2' : 'lg:order-1'}`}>
              <div class="space-y-4">
                <!-- Project Meta -->
                <div class="flex flex-wrap gap-2">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-700">
                    {project.data.technology}
                  </span>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-700">
                    {project.data.category}
                  </span>
                  <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-medium ${
                    project.data.status === 'Live' ? 'bg-emerald-100 text-emerald-800' :
                    project.data.status === 'In Development' ? 'bg-yellow-100 text-yellow-800' :
                    'bg-purple-100 text-purple-800'
                  }`}>
                    {project.data.status}
                  </span>
                  {project.data.timeline && (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-700">
                      {project.data.timeline}
                    </span>
                  )}
                  {project.data.dataScale && (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-100 text-primary-700">
                      {project.data.dataScale}
                    </span>
                  )}
                </div>

                <!-- Project Title and Description -->
                <div>
                  <h2 class="text-2xl font-bold text-gray-900 group-hover:text-primary-600 transition-colors duration-200">
                    {project.data.title}
                  </h2>
                  <p class="mt-2 text-gray-600 text-lg">
                    {project.data.description}
                  </p>
                </div>

                <!-- Client Info -->
                <div class="text-sm text-gray-500">
                  <span class="font-medium">Client:</span> {project.data.client}
                </div>

                <!-- Read More Link -->
                <div class="pt-4">
                  <a 
                    href={`/portfolio/${project.slug}`}
                    class="inline-flex items-center text-primary-600 hover:text-primary-800 font-medium group-hover:underline transition-colors duration-200"
                  >
                    Read Full Case Study
                    <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- Charity Websites Section -->
  <div class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-6">
          Charity Websites We've Built
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Every quarter, we build a website for a charity free of charge. Here are some of the 
          organizations we've been proud to support.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- SDSA -->
        <div class="bg-white rounded-xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-shadow duration-300 group">
          <div class="aspect-square bg-gradient-to-br from-red-50 to-red-100 rounded-xl flex items-center justify-center mb-4 group-hover:scale-105 transition-transform duration-300">
            <div class="text-center text-red-600">
              <svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
              </svg>
              <p class="text-xs font-medium">SDSA</p>
            </div>
          </div>
          <h3 class="text-lg font-bold text-black mb-2">Southampton Disability Sports Association</h3>
          <p class="text-gray-600 text-sm mb-3">
            Supporting disabled sports in Southampton.
          </p>
          <div class="flex items-center justify-between">
            <div class="text-xs text-primary-500 font-medium">Free Charity Website</div>
            <svg class="w-4 h-4 text-gray-400 group-hover:text-primary-500 transition-colors duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </div>

        <!-- Wessex Whisky Club -->
        <div class="bg-white rounded-xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-shadow duration-300 group">
          <div class="aspect-square bg-gradient-to-br from-amber-50 to-amber-100 rounded-xl flex items-center justify-center mb-4 group-hover:scale-105 transition-transform duration-300">
            <div class="text-center text-amber-600">
              <svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
              </svg>
              <p class="text-xs font-medium">Wessex Whisky</p>
            </div>
          </div>
          <h3 class="text-lg font-bold text-black mb-2">Wessex Whisky Club</h3>
          <p class="text-gray-600 text-sm mb-3">
            A charity-benefiting club for whisky enthusiasts.
          </p>
          <div class="flex items-center justify-between">
            <div class="text-xs text-primary-500 font-medium">Free Charity Website</div>
            <svg class="w-4 h-4 text-gray-400 group-hover:text-primary-500 transition-colors duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </div>

        <!-- The Lace Guild -->
        <div class="bg-white rounded-xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-shadow duration-300 group">
          <div class="aspect-square bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl flex items-center justify-center mb-4 group-hover:scale-105 transition-transform duration-300">
            <div class="text-center text-purple-600">
              <svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4 4 4 0 004-4V5z"></path>
              </svg>
              <p class="text-xs font-medium">Lace Guild</p>
            </div>
          </div>
          <h3 class="text-lg font-bold text-black mb-2">The Lace Guild</h3>
          <p class="text-gray-600 text-sm mb-3">
            Preserving traditional lace-making crafts.
          </p>
          <div class="flex items-center justify-between">
            <div class="text-xs text-primary-500 font-medium">Free Charity Website</div>
            <svg class="w-4 h-4 text-gray-400 group-hover:text-primary-500 transition-colors duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </div>

        <!-- Two Dogs and an Awning -->
        <div class="bg-white rounded-xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-shadow duration-300 group">
          <div class="aspect-square bg-gradient-to-br from-green-50 to-green-100 rounded-xl flex items-center justify-center mb-4 group-hover:scale-105 transition-transform duration-300">
            <div class="text-center text-green-600">
              <svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
              <p class="text-xs font-medium">Two Dogs</p>
            </div>
          </div>
          <h3 class="text-lg font-bold text-black mb-2">Two Dogs and an Awning</h3>
          <p class="text-gray-600 text-sm mb-3">
            Raising funds for the Trussell Trust.
          </p>
          <div class="flex items-center justify-between">
            <div class="text-xs text-primary-500 font-medium">Free Charity Website</div>
            <svg class="w-4 h-4 text-gray-400 group-hover:text-primary-500 transition-colors duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </div>
      </div>

      <div class="text-center mt-12">
        <a 
          href="/charity" 
          class="inline-flex items-center text-primary-600 hover:text-primary-800 font-medium text-lg group"
        >
          Learn more about our charity work
          <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Call to Action Section -->
  <div class="bg-gray-50 py-16">
    <div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">
        Ready to Start Your Project?
      </h2>
      <p class="text-xl text-gray-600 mb-8">
        Let's discuss how we can help bring your vision to life with modern web technologies.
      </p>
      <a 
        href="/contact" 
        class="inline-flex items-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-primary-500 hover:bg-primary-600 transition-colors duration-200"
      >
        Get In Touch
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</MainLayout>