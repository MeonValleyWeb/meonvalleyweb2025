    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-black mb-6">
          Frequently asked questions
        </h2>
      </div>
      
      <div class="space-y-6">
        <div class="faq-item bg-gray-50 rounded-xl shadow-sm border border-gray-200">
          <button class="faq-question w-full text-left p-6 flex justify-between items-center hover:bg-gray-100 transition-colors duration-200">
