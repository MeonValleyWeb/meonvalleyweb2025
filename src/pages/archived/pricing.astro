          <h3 class="text-xl font-bold text-black mb-4">UK-Based Support</h3>
          <p class="text-gray-600">
            Direct access to WordPress specialists with emergency response 
            available and response times within 2 hours.
          </p>
        </div>

        <div class="bg-white rounded-xl p-8 shadow-lg">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
