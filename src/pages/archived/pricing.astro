---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Pricing - Premium WordPress Hosting | Meon Valley Web" description="Simple, transparent pricing for premium WordPress hosting solutions. Fast, secure, and reliable hosting designed for growing businesses.">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Premium <span class="text-primary-500">WordPress Hosting</span> Solutions
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Fast, secure, and reliable hosting designed for growing businesses. Get your WordPress site online with professional management and 24/7 monitoring.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#pricing" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg">
            Start Hosting Today
          </a>
          <a href="#pricing" class="border-2 border-primary-500 text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-500 hover:text-white transition-colors duration-200 font-medium text-lg">
            View Pricing
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-black mb-6">
          Features
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Everything your business needs
        </p>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto mt-4">
          Professional WordPress hosting with all the tools to grow your online presence.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
        <div class="text-center">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Lightning Fast Performance</h3>
          <ul class="text-gray-600 space-y-2 text-sm">
            <li>• Cloudflare CDN integration</li>
            <li>• SSD storage and optimized servers</li>
            <li>• Advanced caching (Redis, object cache)</li>
            <li>• Performance monitoring and tuning</li>
          </ul>
        </div>

        <div class="text-center">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Enterprise Security</h3>
          <ul class="text-gray-600 space-y-2 text-sm">
            <li>• SSL certificates included</li>
            <li>• Daily automated backups</li>
            <li>• WordPress security hardening</li>
            <li>• Malware scanning and protection</li>
          </ul>
        </div>

        <div class="text-center">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Professional Management</h3>
          <ul class="text-gray-600 space-y-2 text-sm">
            <li>• WordPress core and plugin updates</li>
            <li>• 24/7 uptime monitoring</li>
            <li>• Migration assistance included</li>
            <li>• Staging environments available</li>
          </ul>
        </div>

        <div class="text-center">
          <div class="bg-primary-100 w-16 h-16 rounded-xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M12 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-black mb-4">Expert Support</h3>
          <ul class="text-gray-600 space-y-2 text-sm">
            <li>• UK-based technical support</li>
            <li>• Emergency response available</li>
            <li>• Monthly performance reports</li>
            <li>• Direct access to WordPress specialists</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section id="pricing" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-bold text-black mb-6">
          Simple, Transparent Pricing
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Choose the perfect hosting solution for your business needs.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <!-- Wayfarer Hosting Only -->
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8">
          <div class="text-center mb-8">
            <h3 class="text-2xl font-bold text-black mb-4">Wayfarer</h3>
            <p class="text-sm text-gray-500 mb-4">Hosting Only</p>
            <div class="mb-4">
              <span class="text-5xl font-bold text-black">£30</span>
              <span class="text-gray-600 ml-2">/ monthly</span>
            </div>
          </div>
          
          <ul class="space-y-4 mb-8">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Premium Storage</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Unlimited Bandwidth</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Free SSL Certificate</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Daily Automated Backups</span>
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-700">Email Support</span>
            </li>
          </ul>
          
