---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Web Design Andover | Professional Website Development"
  description="Expert web design services in Andover & Test Valley. Custom WordPress & AstroJS websites for local businesses. Free consultation."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Web Design Hampshire', href: '/web-design-hampshire' },
    { name: 'Andover' },
  ]}
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-32 bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Web Design <span class="text-primary-500">Andover</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Professional website development for Andover and Test Valley businesses. 
          Modern, effective web solutions for North West Hampshire's growing economy.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg">
            Get Free Quote
          </a>
          <a href="tel:+447850037850" class="border-2 border-primary-500 text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-medium text-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Benefits -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Why Andover Businesses Choose Us
        </h2>
        <p class="text-xl text-gray-600">Test Valley's trusted web development partner</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4H9z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Rural & Town Coverage</h3>
          <p class="text-gray-600">
            From Andover town centre to surrounding villages, we understand the unique needs of 
            rural businesses and town-based companies alike.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Affordable Excellence</h3>
          <p class="text-gray-600">
            Andover businesses deserve professional web design without London prices. 
            We offer competitive rates with premium quality.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Local Support</h3>
          <p class="text-gray-600">
            Based in the Meon Valley, we're within easy reach of Andover. Personal service 
            with face-to-face meetings available.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services for Andover -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Web Development Services in Andover
        </h2>
        <p class="text-xl text-gray-600">Complete solutions for Test Valley businesses</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Trades & Services</h3>
          <p class="text-gray-600 mb-4">
            Andover's thriving trades sector needs websites that generate local enquiries. 
            We build sites that rank in local search and convert visitors to customers.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Quote request forms
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Service area maps
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Review integration
            </li>
          </ul>
        </div>
        
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Retail & E-commerce</h3>
          <p class="text-gray-600 mb-4">
            From Andover's town centre shops to rural craft businesses, we create online stores 
            that expand your reach beyond the local area.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Easy product management
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Local delivery options
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Click & collect
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Andover Areas Served -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Serving Andover & Test Valley
        </h2>
        <p class="text-xl text-gray-600">North West Hampshire web design coverage</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Andover Town Centre</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Charlton</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Walcott</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Weyhill</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Thruxton</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Hurstbourne Tarrant</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">St Mary Bourne</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Whitchurch</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Andover Section (Unique Content) -->
  <section class="py-20 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">
          Web Design in the Heart of Test Valley
        </h2>
        <p class="text-lg text-gray-600">
          Serving the SP10 and SP11 postcodes and North West Hampshire's rural economy
        </p>
      </div>

      <div class="prose prose-lg max-w-none text-gray-700">
        <p class="mb-6">
          Andover sits at the confluence of the River Anton and River Test, surrounded by some 
          of Hampshire's most beautiful countryside. This historic market town, with its roots 
          stretching back to Saxon times, has evolved into a vibrant modern centre that balances 
          rural charm with economic dynamism.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-10">
          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <h3 class="text-xl font-bold text-gray-900 mb-3">The Georgian High Street</h3>
            <p class="text-gray-600">
              Andover's elegant Georgian high street is home to a wonderful mix of independent 
              retailers and cafes. We help these businesses compete online, creating websites 
              that capture their unique character while reaching customers beyond the town centre.
            </p>
          </div>

          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Rural Hampshire's Digital Gateway</h3>
            <p class="text-gray-600">
              From the rolling chalk downs to the crystal-clear River Test, the surrounding 
              villages depend on Andover as their local hub. We help rural businesses—from 
              farm shops to B&Bs—reach visitors and customers online.
            </p>
          </div>
        </div>

        <p class="mb-6">
          Our Andover clients reflect the area's unique economy: agricultural suppliers serving 
          the local farming community, boutique accommodation providers welcoming tourists 
          exploring the Test Valley, and skilled tradespeople who've built reputations over 
          generations. Each website we create respects these distinct identities.
        </p>

        <p class="mb-6">
          The town's proximity to the A303 makes it a strategic location for businesses 
          serving both London and the South West. Your website should work as hard as you do, 
          attracting customers from across the region while maintaining that essential local 
          connection that Andover businesses are known for.
        </p>

        <div class="bg-primary-50 p-6 rounded-xl border-l-4 border-primary-500 my-8">
          <p class="text-gray-800 italic">
            "As a family-run business in Andover for 20 years, we needed a website that honoured 
            our heritage while attracting new customers. They absolutely nailed it." 
            — Michael R., Andover Town Centre
          </p>
        </div>

        <h3 class="text-2xl font-bold text-gray-900 mb-4 mt-8">Villages We Serve Around Andover</h3>
        <p class="mb-6">
          The Test Valley area is defined by its charming villages. We regularly work with 
          businesses throughout the surrounding countryside:
        </p>

        <ul class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-8">
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Weyhill (SP11)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Thruxton (SP11)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Hurstbourne Tarrant (SP11)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Whitchurch (RG28)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            St Mary Bourne (SP11)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Ludgershall (SP11)
          </li>
        </ul>

        <p class="mb-6">
          We understand the rhythm of rural business life. Whether you need a simple brochure 
          site to establish credibility or a full e-commerce solution to sell your products 
          nationwide, we deliver solutions that respect your budget and exceed your expectations.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        Let's grow your Andover business online
      </h2>
      <p class="text-xl text-primary-100 mb-8">
        Free consultation for Test Valley businesses. Call <a href="tel:+447850037850" class="underline">07850 037850</a> or book online.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors duration-200 font-medium text-lg">
          Get Your Quote
        </a>
        <a href="tel:+447850037850" class="border-2 border-white text-white px-8 py-4 rounded-lg hover:bg-white hover:text-primary-500 transition-colors duration-200 font-medium text-lg">
          Call 07850 037850
        </a>
      </div>
    </div>
  </section>
</MainLayout>
