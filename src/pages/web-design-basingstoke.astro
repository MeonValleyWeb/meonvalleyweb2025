---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Web Design Basingstoke | Professional Website Development"
  description="Expert web design services in Basingstoke. Custom WordPress & AstroJS websites for local businesses. Free consultation & Hampshire-based support."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Web Design Hampshire', href: '/web-design-hampshire' },
    { name: 'Basingstoke' },
  ]}
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-32 bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Web Design <span class="text-primary-500">Basingstoke</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Professional website development for Basingstoke businesses. Serving the town centre, 
          business parks, and surrounding areas with modern, effective web solutions.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg">
            Get Free Quote
          </a>
          <a href="tel:+447850037850" class="border-2 border-primary-500 text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-medium text-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Benefits -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Web Design for Basingstoke Businesses
        </h2>
        <p class="text-xl text-gray-600">North Hampshire's trusted web development partner</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Corporate Ready</h3>
          <p class="text-gray-600">
            Basingstoke's business parks and corporate sector need professional, scalable websites. 
            We deliver enterprise-quality solutions for growing companies.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Growth Focused</h3>
          <p class="text-gray-600">
            As Basingstoke expands, your website should grow with you. We build scalable platforms 
            that evolve as your business develops.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Local & Accessible</h3>
          <p class="text-gray-600">
            Based in the Meon Valley, we're just 30 minutes away. Available for meetings at your 
            Basingstoke office or at our Hampshire studio.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services for Basingstoke -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Web Development Services in Basingstoke
        </h2>
        <p class="text-xl text-gray-600">Enterprise-grade solutions for North Hampshire</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Corporate & Enterprise</h3>
          <p class="text-gray-600 mb-4">
            Basingstoke's corporate sector demands professional, feature-rich websites. We build 
            scalable solutions for businesses of all sizes.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Multi-language support
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Intranet/extranet capability
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Advanced integrations
            </li>
          </ul>
        </div>
        
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Startups & SMEs</h3>
          <p class="text-gray-600 mb-4">
            Basingstoke's vibrant startup scene needs cost-effective, professional web presence 
            that punches above its weight.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Startup-friendly pricing
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Rapid MVP development
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Growth-ready architecture
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Basingstoke Areas Served -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Serving Basingstoke & Surrounding Areas
        </h2>
        <p class="text-xl text-gray-600">North Hampshire web design coverage</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Basingstoke Town Centre</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Chineham Business Park</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Bramley</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Tadley</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Old Basing</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Kempshott</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">South View</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Winklebury</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Basingstoke Section (Unique Content) -->
  <section class="py-20 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">
          Web Design for Basingstoke's Thriving Business Community
        </h2>
        <p class="text-lg text-gray-600">
          Serving the 01256 area and North Hampshire's economic powerhouse
        </p>
      </div>

      <div class="prose prose-lg max-w-none text-gray-700">
        <p class="mb-6">
          Basingstoke isn't just another Hampshire town—it's one of the UK's most economically significant 
          areas outside London. With major business parks like Chineham, Viables, and the basingstoke 
          Business Centre housing everything from tech giants to innovative startups, the digital 
          landscape here is competitive.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-10">
          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Festival Place & The Malls</h3>
            <p class="text-gray-600">
              Just as Festival Place transformed Basingstoke's retail offering, we transform 
              businesses' digital presence. From independent retailers in The Malls to national 
              chains, we create e-commerce that converts.
            </p>
          </div>

          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <h3 class="text-xl font-bold text-gray-900 mb-3">The Anvil & Cultural Quarter</h3>
            <p class="text-gray-600">
              Basingstoke's thriving arts scene needs websites as impressive as the performances 
              at The Anvil. We help theatres, galleries, and cultural venues sell tickets and 
              promote events online.
            </p>
          </div>
        </div>

        <p class="mb-6">
          Our Basingstoke clients span the full economic spectrum—from one-person consultancies 
          working from co-working spaces like DeskLodge, to established companies at Chineham 
          Business Park with 50+ employees. Each gets a solution scaled to their needs and budget.
        </p>

        <p class="mb-6">
          The town's excellent rail links (just 45 minutes to London Waterloo) mean many Basingstoke 
          businesses serve clients nationwide while maintaining their Hampshire base. Your website 
          needs to reflect that professional reach while keeping local credibility.
        </p>

        <div class="bg-primary-50 p-6 rounded-xl border-l-4 border-primary-500 my-8">
          <p class="text-gray-800 italic">
            "As a Basingstoke tech company, we needed a website that matched our technical standards. 
            The result exceeded expectations—clean code, fast performance, and leads that convert." 
            — James T., Chineham Business Park
          </p>
        </div>

        <h3 class="text-2xl font-bold text-gray-900 mb-4 mt-8">Serving All of North Hampshire</h3>
        <p class="mb-6">
          While Basingstoke is our focus, we regularly work with businesses throughout the 
          surrounding area including:
        </p>

        <ul class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-8">
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Old Basing (RG24)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Bramley (RG26)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Tadley (RG26)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Kempshott (RG22)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Hatch Warren (RG22)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Brighton Hill (RG22)
          </li>
        </ul>

        <p class="mb-6">
          Whether you're a startup looking for your first website or an established business 
          needing a digital refresh, we offer the technical expertise and local understanding 
          to deliver results. Our office is just 30 minutes away, making face-to-face meetings 
          convenient whenever you need them.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        Let's build your Basingstoke business online
      </h2>
      <p class="text-xl text-primary-100 mb-8">
        Free consultation for North Hampshire businesses. Call <a href="tel:+447850037850" class="underline">07850 037850</a> or book online.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors duration-200 font-medium text-lg">
          Start Your Project
        </a>
        <a href="tel:+447850037850" class="border-2 border-white text-white px-8 py-4 rounded-lg hover:bg-white hover:text-primary-500 transition-colors duration-200 font-medium text-lg">
          Call 07850 037850
        </a>
      </div>
    </div>
  </section>
</MainLayout>
