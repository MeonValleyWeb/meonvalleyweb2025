---
import MainLayout from '../layouts/MainLayout.astro';
import SchemaFAQ from '../components/SchemaFAQ.astro';

const basingstokeFAQs = [
  {
    question: "Do you work with Basingstoke businesses?",
    answer: "Yes, we work extensively with businesses across Basingstoke. From the town centre and Festival Place area to business parks like Chineham and Houndmills, we help local companies establish a professional online presence. Our Basingstoke clients include professional services, retailers, technology companies, and corporate businesses."
  },
  {
    question: "How much does a website cost in Basingstoke?",
    answer: "Our Basingstoke web design projects typically start from £2,500 for a professional small business website. This includes custom design, mobile optimisation, basic SEO, and training. Corporate and e-commerce websites start from £4,500. We provide transparent, fixed-price quotes tailored to Basingstoke businesses with no hidden costs."
  },
  {
    question: "What areas in Basingstoke do you cover?",
    answer: "We serve businesses throughout Basingstoke including the town centre (RG21), Chineham (RG24), South Ham, Popley, Hatch Warren, and surrounding areas. We cover RG21, RG22, RG23, and RG24 postcodes. Whether you're based in a business park, retail location, or office building, we can help with your web design project."
  },
  {
    question: "Can you help Basingstoke corporate businesses with websites?",
    answer: "Absolutely. We specialise in professional corporate websites for Basingstoke businesses. Our designs include staff profiles, service showcases, case studies, document libraries, and integration with business systems. We understand the professional standards required by Basingstoke's diverse business community."
  },
  {
    question: "Do you offer WordPress development for Basingstoke businesses?",
    answer: "Yes, we provide comprehensive WordPress services for Basingstoke businesses including custom theme development, plugin integration, managed hosting with 99.9% uptime, and ongoing maintenance packages. Whether you need a new WordPress site or improvements to an existing one, we have the expertise."
  },
  {
    question: "How quickly can you build a website for my Basingstoke business?",
    answer: "Most Basingstoke business websites are completed within 2-4 weeks. Simple brochure sites can be ready in 2 weeks, while more complex corporate sites take 4-6 weeks. We provide a detailed timeline during our free consultation and keep you updated throughout."
  },
  {
    question: "Can you help my Basingstoke business rank on Google?",
    answer: "Yes, all our websites are built with SEO best practices including fast loading times, mobile optimisation, schema markup, and proper heading structures. For Basingstoke businesses specifically, we optimise for local search terms like 'web design Basingstoke' and your services combined with location keywords."
  }
];
---

<SchemaFAQ faqs={basingstokeFAQs} />

<MainLayout 
  title="Web Design Basingstoke | Professional Website Development" 
  description="Expert web design services in Basingstoke. Custom WordPress & AstroJS websites for local businesses. Free consultation & Hampshire-based support."
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-32 bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Web Design <span class="text-primary-500">Basingstoke</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Professional website development for Basingstoke businesses. Serving the town centre, 
          business parks, and surrounding areas with modern, effective web solutions.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg">
            Get Free Quote
          </a>
          <a href="tel:+447850037850" class="border-2 border-primary-500 text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-medium text-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Benefits -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Web Design for Basingstoke Businesses
        </h2>
        <p class="text-xl text-gray-600">North Hampshire's trusted web development partner</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Corporate Ready</h3>
          <p class="text-gray-600">
            Basingstoke's business parks and corporate sector need professional, scalable websites. 
            We deliver enterprise-quality solutions for growing companies.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Growth Focused</h3>
          <p class="text-gray-600">
            As Basingstoke expands, your website should grow with you. We build scalable platforms 
            that evolve as your business develops.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
