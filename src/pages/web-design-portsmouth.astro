---
import MainLayout from '../layouts/MainLayout.astro';
import SchemaFAQ from '../components/SchemaFAQ.astro';

const portsmouthFAQs = [
  {
    question: "Do you work with Portsmouth businesses?",
    answer: "Yes, we work extensively with businesses across Portsmouth. From Southsea and Old Portsmouth to the city centre and Portsea, we help local companies establish a strong digital presence. Our Portsmouth clients include retailers, professional services, tradespeople, and hospitality businesses."
  },
  {
    question: "How much does a website cost in Portsmouth?",
    answer: "Our Portsmouth web design projects typically start from £2,500 for a professional small business website. This includes custom design, mobile optimisation, basic SEO setup, and CMS training. E-commerce websites start from £4,500. We provide fixed-price quotes with no hidden costs."
  },
  {
    question: "What areas in Portsmouth do you cover?",
    answer: "We serve businesses throughout Portsmouth including Southsea, Old Portsmouth, Fratton, Copnor, Milton, Baffins, and surrounding areas. We cover PO1, PO2, PO3, PO4, PO5, and PO6 postcodes. Whether you're based in the city centre or the suburbs, we can help with your web design project."
  },
  {
    question: "Can you help Portsmouth hospitality businesses with websites?",
    answer: "Absolutely. We specialise in websites for Portsmouth restaurants, cafes, pubs, and hospitality businesses. Our designs include table booking integration, menu displays, event calendars, and online ordering systems. We understand the unique needs of the hospitality sector in Portsmouth."
  },
  {
    question: "Do you offer e-commerce web design for Portsmouth retailers?",
    answer: "Yes, we create e-commerce websites for Portsmouth retailers wanting to sell online. Using WooCommerce or Shopify, we build online stores with secure payments, inventory management, and click-and-collect functionality. Perfect for Southsea independent shops and Portsmouth retail businesses."
  },
  {
    question: "How quickly can you build a website for my Portsmouth business?",
    answer: "Most Portsmouth business websites are completed within 2-4 weeks. Simple brochure sites can be ready in 2 weeks, while more complex e-commerce sites take 4-6 weeks. We provide a detailed timeline during our free consultation and keep you updated throughout the build process."
  },
  {
    question: "Can you help my Portsmouth business appear on Google Maps?",
    answer: "Yes, we optimise your website for local SEO and can help set up and optimise your Google Business Profile. This helps you appear in Google Maps searches and local 'near me' searches for Portsmouth customers. All our websites include schema markup for better local search visibility."
  }
];
---

<SchemaFAQ faqs={portsmouthFAQs} />

<MainLayout 
  description="Expert web design services in Portsmouth. Custom WordPress, AstroJS & headless websites for local businesses. Free consultation & transparent pricing."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Web Design Hampshire', href: '/web-design-hampshire' },
    { name: 'Portsmouth' },
  ]}
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-32 bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Web Design <span class="text-primary-500">Portsmouth</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Professional website development for Portsmouth businesses. From Southsea to Old Portsmouth, 
          we create modern, mobile-friendly websites that help local companies grow online.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg">
            Get Free Quote
          </a>
          <a href="tel:+447850037850" class="border-2 border-primary-500 text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-medium text-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Benefits -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Why Portsmouth Businesses Choose Us
        </h2>
        <p class="text-xl text-gray-600">Local expertise with professional results</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Local Knowledge</h3>
          <p class="text-gray-600">
            We understand Portsmouth's business landscape, from the maritime industry to tourism 
            and retail in Gunwharf Quays. Your website will resonate with local customers.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Quick Response</h3>
          <p class="text-gray-600">
            Just 30 minutes from Portsmouth, we offer fast response times and the option for 
            face-to-face meetings to discuss your project in person.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Local SEO Focus</h3>
          <p class="text-gray-600">
            We optimise your website for Portsmouth-specific searches, helping you rank for 
            terms like "web designer Portsmouth" and "Southsea business website."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services for Portsmouth -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Web Development Services in Portsmouth
        </h2>
        <p class="text-xl text-gray-600">Tailored solutions for Portsmouth businesses</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">WordPress Websites</h3>
          <p class="text-gray-600 mb-4">
            Perfect for Portsmouth retailers, restaurants, and service businesses. Easy-to-manage 
            content, booking systems, and e-commerce functionality.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Custom WordPress themes
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              WooCommerce integration
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Local SEO optimisation
            </li>
          </ul>
        </div>
        
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Headless & AstroJS</h3>
          <p class="text-gray-600 mb-4">
            Lightning-fast static sites for businesses that need speed. Ideal for portfolios, 
            marketing sites, and content-heavy websites.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Blazing fast performance
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Perfect Core Web Vitals
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Enhanced security
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Portsmouth Areas Served -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Serving All of Portsmouth
        </h2>
        <p class="text-xl text-gray-600">We work with businesses across the Portsmouth area</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Southsea</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Old Portsmouth</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Gunwharf Quays</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Fratton</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Milton</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Drayton</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Cosham</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Port Solent</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Frequently Asked Questions
        </h2>
        <p class="text-xl text-gray-600">Common questions about our Portsmouth web design services</p>
      </div>
      
      <div class="space-y-4">
        {portsmouthFAQs.map((faq, index) => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <details class="group">
              <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                <h3 class="text-lg font-semibold text-gray-900 pr-4">{faq.question}</h3>
                <span class="transition-transform duration-200 group-open:rotate-180">
                  <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-gray-600 leading-relaxed">
                {faq.answer}
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        Ready to grow your Portsmouth business online?
      </h2>
      <p class="text-xl text-primary-100 mb-8">
        Get a free consultation and quote. No obligation, just honest advice for your business.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors duration-200 font-medium text-lg">
          Start Your Project
        </a>
        <a href="/services" class="border-2 border-white text-white px-8 py-4 rounded-lg hover:bg-white hover:text-primary-500 transition-colors duration-200 font-medium text-lg">
          View All Services
        </a>
      </div>
    </div>
  </section>
</MainLayout>
