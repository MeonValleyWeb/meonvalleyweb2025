---
import MainLayout from '../layouts/MainLayout.astro';
import SchemaFAQ from '../components/SchemaFAQ.astro';

const romseyFAQs = [
  {
    question: "Do you work with Romsey businesses?",
    answer: "Yes, we work extensively with businesses in Romsey and surrounding villages. From the historic market town centre near the Abbey to businesses in areas like Cupernham and Woodley, we help local companies establish a professional online presence. Our Romsey clients include independent retailers, professional services, hospitality businesses, and tradespeople."
  },
  {
    question: "How much does a website cost in Romsey?",
    answer: "Our Romsey web design projects typically start from £2,500 for a professional small business website. This includes custom design, mobile optimisation, basic SEO setup, and CMS training. E-commerce websites for Romsey retailers start from £4,500. We provide transparent, fixed-price quotes with no hidden costs."
  },
  {
    question: "What areas around Romsey do you cover?",
    answer: "We serve businesses throughout the Romsey area including the town centre (SO51), surrounding villages like Wellow, Timsbury, Michelmersh, and the wider Test Valley. Whether you're based in Romsey town or the surrounding Hampshire countryside, we can help with your web design project."
  },
  {
    question: "Can you help Romsey hospitality businesses with websites?",
    answer: "Absolutely. Romsey's charming hospitality scene benefits from professional websites. We specialise in creating websites for Romsey restaurants, pubs, B&Bs, and guest houses. Our designs include booking systems, menu displays, event calendars, and integration with local tourism platforms. We understand what makes Romsey hospitality businesses special."
  },
  {
    question: "Do you offer WordPress support for Romsey businesses?",
    answer: "Yes, we provide comprehensive WordPress services for Romsey businesses including custom theme development, managed hosting with 99.9% uptime, security monitoring, and ongoing maintenance packages. We can help with new WordPress sites or improvements to existing ones."
  },
  {
    question: "How quickly can you build a website for my Romsey business?",
    answer: "Most Romsey business websites are completed within 2-4 weeks. Simple brochure sites can be ready in 2 weeks, while more complex projects take 4-6 weeks. We provide a detailed timeline during our free consultation and keep you updated throughout the process."
  },
  {
    question: "Can you help my Romsey business rank on Google?",
    answer: "Yes, all our websites are built with SEO best practices including fast loading times, mobile optimisation, schema markup, and proper heading structures. For Romsey businesses specifically, we optimise for local search terms like 'web design Romsey' and your services combined with location keywords."
  }
];
---

<SchemaFAQ faqs={romseyFAQs} />

<MainLayout 
  title="Web Design Romsey | Professional Website Development" 
  description="Expert web design services in Romsey & Test Valley. Custom WordPress & AstroJS websites for local businesses. Free consultation."
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-32 bg-gradient-to-br from-white via-primary-50/30 to-primary-100/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          Web Design <span class="text-primary-500">Romsey</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Professional website development for Romsey businesses. Serving this historic market town 
          and surrounding Hampshire villages with modern web solutions.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-primary-500 text-white px-8 py-4 rounded-lg hover:bg-primary-600 transition-colors duration-200 font-medium text-lg">
            Get Free Quote
          </a>
          <a href="tel:+447850037850" class="border-2 border-primary-500 text-primary-500 px-8 py-4 rounded-lg hover:bg-primary-50 transition-colors duration-200 font-medium text-lg flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Benefits -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Web Design for Romsey Businesses
        </h2>
        <p class="text-xl text-gray-600">Heritage town, modern web solutions</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v4H9z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Market Town Expertise</h3>
          <p class="text-gray-600">
            We understand Romsey's unique blend of independent shops, rural businesses, and 
            proximity to Southampton. Websites that reflect your character.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Rural Reach</h3>
          <p class="text-gray-600">
            Extend your reach beyond Romsey's high street. Our websites help you attract customers 
            from across Test Valley and beyond.
          </p>
        </div>
        
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Local & Nearby</h3>
          <p class="text-gray-600">
            Just 25 minutes from Romsey, we're close enough for face-to-face meetings while 
            offering the expertise of an established agency.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services for Romsey -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Web Development Services in Romsey
        </h2>
        <p class="text-xl text-gray-600">Perfect for independent businesses and rural enterprises</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Independent Shops</h3>
          <p class="text-gray-600 mb-4">
            Romsey's charming independent retailers need websites that capture their unique character. 
            From the Cornmarket to Bell Street, we help local shops thrive online.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              E-commerce integration
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Local SEO focus
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Opening hours & location
            </li>
          </ul>
        </div>
        
        <div class="bg-white rounded-xl p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Rural & Farm Businesses</h3>
          <p class="text-gray-600 mb-4">
            From farm shops to countryside B&Bs, we create websites that showcase the best of 
            rural Romsey and attract visitors from across Hampshire.
          </p>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Beautiful galleries
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Online booking systems
            </li>
            <li class="flex items-center">
              <svg class="w-5 h-5 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Event promotion
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Romsey Areas Served -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Serving Romsey & Surrounding Villages
        </h2>
        <p class="text-xl text-gray-600">Test Valley web design coverage</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Romsey Town Centre</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">North Baddesley</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">East Wellow</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Sherfield English</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Awbridge</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Braishfield</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Michelmersh</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <p class="font-semibold text-gray-900">Timsbury</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Romsey Section (Unique Content) -->
  <section class="py-20 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">
          Web Design for Romsey's Independent Spirit
        </h2>
        <p class="text-lg text-gray-600">
          Serving the SO51 postcode and the charming Test Valley market town
        </p>
      </div>

      <div class="prose prose-lg max-w-none text-gray-700">
        <p class="mb-6">
          Romsey is that rare gem—a thriving market town that has retained its soul. As you wander 
          down the Cornmarket, past the magnificent Norman Abbey that dominates the skyline, you'll 
          find a high street where independent businesses flourish alongside familiar names. This 
          is a town that values character over chains, and that ethos is exactly what we capture 
          in the websites we build for Romsey businesses.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-10">
          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <h3 class="text-xl font-bold text-gray-900 mb-3">Romsey Abbey & Market Square</h3>
            <p class="text-gray-600">
              The ancient Abbey and bustling Thursday market define Romsey's character. We help 
              local traders, cafes, and shops around the square create digital presences that 
              are as welcoming as their physical storefronts.
            </p>
          </div>

          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <h3 class="text-xl font-bold text-gray-900 mb-3">King John's House</h3>
            <p class="text-gray-600">
              Just like this medieval merchant's house tells Romsey's history, your website 
              tells your story. We specialise in websites for heritage businesses, museums, 
              and tourist attractions throughout the area.
            </p>
          </div>
        </div>

        <p class="mb-6">
          Our Romsey clients are wonderfully diverse—the artisan jeweller in Church Street, the 
          family-run tea room near the Abbey, the farm shop selling produce from the surrounding 
          Test Valley villages, the bed and breakfast welcoming walkers along the Test Way. Each 
          business has its own story, and we make sure their website tells it beautifully.
        </p>

        <p class="mb-6">
          Romsey's position just 8 miles from Southampton gives businesses here the best of both 
          worlds—a peaceful market town atmosphere with easy access to a major city. Many of 
          our Romsey clients serve both the local community and customers from across Hampshire 
          who've discovered them online.
        </p>

        <div class="bg-primary-50 p-6 rounded-xl border-l-4 border-primary-500 my-8">
          <p class="text-gray-800 italic">
            "Our website perfectly captures the feel of our shop in the Cornmarket. Customers 
            tell us they felt like they knew us before they even walked through the door." 
            — Emma L., Romsey Independent Retailer
          </p>
        </div>

        <h3 class="text-2xl font-bold text-gray-900 mb-4 mt-8">Nearby Villages We Serve</h3>
        <p class="mb-6">
          The beauty of Romsey is its connection to the surrounding countryside. We work with 
          businesses across the SO51 area and beyond:
        </p>

        <ul class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-8">
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            North Baddesley (SO52)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            East Wellow (SO51)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Sherfield English (SO51)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Awbridge (SO51)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Braishfield (SO51)
          </li>
          <li class="flex items-center text-gray-700">
            <svg class="w-4 h-4 text-primary-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            Michelmersh (SO51)
          </li>
        </ul>

        <p class="mb-6">
          Whether you're selling artisan crafts to tourists visiting the Abbey, running a 
          countryside B&B for Test Way walkers, or providing services to the local community, 
          we'll create a website that feels authentically you—professional yet personal, just 
          like Romsey itself.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">
          Frequently Asked Questions
        </h2>
        <p class="text-xl text-gray-600">Common questions about our Romsey web design services</p>
      </div>
      
      <div class="space-y-4">
        {romseyFAQs.map((faq, index) => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
            <details class="group">
              <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                <h3 class="text-lg font-semibold text-gray-900 pr-4">{faq.question}</h3>
                <span class="transition-transform duration-200 group-open:rotate-180">
                  <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-gray-600 leading-relaxed">
                {faq.answer}
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        Ready to take your Romsey business online?
      </h2>
      <p class="text-xl text-primary-100 mb-8">
        Free consultation for Romsey and Test Valley businesses. Call <a href="tel:+447850037850" class="underline">07850 037850</a>.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-white text-primary-500 px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors duration-200 font-medium text-lg">
          Start Your Project
        </a>
        <a href="tel:+447850037850" class="border-2 border-white text-white px-8 py-4 rounded-lg hover:bg-white hover:text-primary-500 transition-colors duration-200 font-medium text-lg">
          Call 07850 037850
        </a>
      </div>
    </div>
  </section>
</MainLayout>
